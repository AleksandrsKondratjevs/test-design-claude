/**
 * This is abstract functionality to init simple bar library.
 * It is used as floating bar, since default browser css doesn't allow to have overflow overlay.
 * Example:
 *
 * <div data-simplebar />
 *
 * Attribute data-simplebar will init custom floating bar, example can be found in
 * dropdown.phtml file.
 *
 * It is required to init it in component initialization by using window.initSimplebar.
 * It will execute injection only once, therefor save to use in multiple places without worry of multiple
 * injections.
 */

$simplebarUrl = $block->getViewFileUrl('Hyva_Theme::js/simplebar.min.js');
$simplebarCssUrl = $block->getViewFileUrl('Hyva_Theme::css/simplebar.min.css');
?>


<script>
    window.simplebarInitializing = false;
    window.simplebarPromise = null;

    function initSimplebar(options = {}) {
        const addSwiperJs = (callback) => {
            const script = document.createElement('script');
            script.type = 'text/javascript';
            script.addEventListener('load', callback);
            script.src = '<?= $escaper->escapeJs($escaper->escapeUrl($simplebarUrl)) ?>';
            document.head.appendChild(script);
        }

        const addSimplebarCss = () => {
            const link = document.createElement('link');
            link.type = 'text/css';
            link.rel = 'stylesheet';
            link.href = '<?= $escaper->escapeJs($escaper->escapeUrl($simplebarCssUrl)) ?>';
            document.head.appendChild(link);
        }

        if (!window.simplebarInitializing) {
            if (!window.simplebarPromise) {
                window.simplebarPromise = new Promise((resolve) => {
                    window.simplebarInitializing = true;
                    addSimplebarCss();
                    addSwiperJs(() => {
                        resolve();
                    });
                });
            }
        }
    }
</script>