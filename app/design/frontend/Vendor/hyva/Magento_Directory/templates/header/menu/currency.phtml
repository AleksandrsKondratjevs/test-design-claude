declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\Currency;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\SvgIcons;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

// phpcs:disable Generic.Files.LineLength.TooLong

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

/** @var Currency $currencyViewModel */
$currencyViewModel = $viewModels->require(Currency::class);

$uniqueId = uniqid('_');

if ($currencyViewModel->getCurrencyCount() <= 1) {
    return '';
}

$currencies = $currencyViewModel->getCurrencies();
$currentCurrencyCode = $currencyViewModel->getCurrentCurrencyCode();
$currentCurrencyName = $currencies[$currentCurrencyCode] ?: '';

/** @var Hyva\Theme\ViewModel\Locale $locale */
$locale = class_exists('Hyva\Theme\ViewModel\Locale')
    ? $viewModels->require(Hyva\Theme\ViewModel\Locale::class)
    : null;

/**
 * The method below was introduced in version 1.3.10 of the Hyva_Theme module.
 * Please upgrade to enable the locale trough the store config instead of the users device setting.
 */
$currentLocale = $locale && method_exists($locale, 'getLocale') ? $locale->getLocale() : '';
?>

<script>
    function currencyDropdown<?= $uniqueId ?>() {
        return  {
            locale: '<?= /* @noEscape */ $currentLocale ?>',
            currentCurrency: {
                code: '<?= $escaper->escapeJs($currentCurrencyCode) ?>',
                name: '<?= $escaper->escapeJs($currentCurrencyName) ?>',
            },
            currencies: <?= /* @noEscape */ json_encode($currencies) ?>,
            currenciesWithoutCurrent: {},
            isStateDropdownOpen: false,
            selectedCurrency: '<?= $currentCurrencyCode ?>',

            getCurrencySymbol(code) {
                try {
                    const formatter = new Intl.NumberFormat(this.locale || undefined, { style: 'currency', currency: code });
                    const parts = formatter.formatToParts(1);
                    const symbolPart = parts.find(part => part.type === 'currency');
                    return symbolPart ? symbolPart.value : code;
                } catch (error) {
                    console.error(`Error getting currency symbol for ${code}:`, error);
                    return code;
                }
            },
            getCurrencyLabel(code) {
                return `${code} (${this.getCurrencySymbol(code)})`;
            },
            setCurrency(code) {
                hyva.postForm({
                    'action': '<?= $escaper->escapeUrl($block->getUrl('directory/currency/switch')) ?>',
                    'data': {
                        'currency': code,
                        'uenc': hyva.getUenc()
                    }
                });
            },
            handleOptionSelectState(value) {
                this.selectedCurrency = value;
                this.setCurrency(value);
            },
            handleClick(event) {
                if (Alpine.store('device')?.isDesktop && event.pointerType === 'mouse') {
                    this.isStateDropdownOpen = !this.isStateDropdownOpen;
                }
            },
        }
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>
<fieldset class="fieldset" x-data="currencyDropdown<?= $uniqueId ?>">
        <div
            class="field"
            x-cloak
        >
            <label class="label" for="currency" @click="$event.preventDefault();">
                <span><?= $escaper->escapeHtml(__('Currency')) ?></span>
            </label>
            <div class="control">
                <div
                    class="form-select-wrapper"
                >
                    <select
                        class="form-select w-full"
                        @mousedown="$store.device.isDesktop ? $event.preventDefault() : null"
                        @click="handleClick"
                        @mouseup="$store.device.isDesktop ? $event.preventDefault() : null"
                        x-model="selectedCurrency"
                        x-ref="currency"
                        id="currency"
                        name="currency"
                        @input.debounce="setCurrency()"
                    >
                        <template x-for="currency in Object.entries(currencies)">
                            <?php /* in alpine v3, if the bound props update, the template body gets evaluated before the template condition */ ?>
                            <?php /* because of this it is required to check if availableRegions[regionId] is set */ ?>
                            <option :value="currency[0]"
                                    :name="currency[0]"
                                    x-text="getCurrencyLabel(currency[0])"
                                    :selected="selectedCurrency === currency[0]"
                            >
                            </option>
                        </template>
                    </select>
                    <div class="chevron" :class="{ 'chevron-opened': isStateDropdownOpen }">
                        <!-- Change to your chevron or custom icon -->
                        <?= $heroicons->chevronDownHtml('', 16, 16) ?>
                    </div>
                    <ul
                        x-cloak
                        x-show="isStateDropdownOpen"
                        @click.away="isStateDropdownOpen = false"
                        class="form-select-options-list"
                        tabindex="0"
                        x-ref="stateDropdown"
                    >
                        <template x-for="(currency, index) in Object.entries(currencies)">
                            <li
                                @click="handleOptionSelectState(currency[0]);"
                                class="form-select-option"
                                :class="{ 'form-select-option-selected': selectedCurrency === currency[0] }"
                                :name="currency[0]"
                                x-text="getCurrencyLabel(currency[0])"
                                :selected="selectedCurrency === currency[0]"
                                :tabindex="index"
                                :key="index"
                            >
                            </li>
                        </template>
                    </ul>
                </div>
            </div>
        </div>
</fieldset>