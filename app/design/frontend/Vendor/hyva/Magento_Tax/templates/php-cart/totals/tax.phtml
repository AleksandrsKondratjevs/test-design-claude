 */
?>
<template x-if="segment.code === 'tax' && (segment.value > 0 || checkoutConfig.isZeroTaxDisplayed)">
    <div>
        <template x-if="!(segment.value > 0 && checkoutConfig.isFullTaxSummaryDisplayed)">
            <div :class="wrapperClass">
                <div x-text="segment.title"></div>
                <div x-text="hyva.formatPrice(segment.value)" class="justify-self-end font-bold"></div>
            </div>
        </template>

        <template x-if="segment.value > 0 && checkoutConfig.isFullTaxSummaryDisplayed">
            <details class="group">
                <summary class="cursor-pointer [&::-webkit-details-marker]:hidden" :class="wrapperClass">
                    <span x-text="segment.title" class="items-center"></span>
                    <span class="inline-flex items-center gap-x-1 justify-self-end justify-end md:w-auto">
                        <span x-text="hyva.formatPrice(segment.value)" class="font-bold"></span>
                        <?= $heroicons->chevronDownHtml('transform group-open:rotate-180', 24, 24, ['aria-hidden' => 'true']); ?>
                    </span>
                </summary>

                <div class="col-span-2">
                    <template x-for="(taxItem, index) in segment.extension_attributes.tax_grandtotal_details" :key="index">
                        <div :class="wrapperClass">
                            <div>
                                <template x-for="(taxRate, index) in taxItem.rates">
                                    <div x-text="`${taxRate.title} (${taxRate.percent}%)`"></div>
                                </template>
                            </div>
                            <div x-text="hyva.formatPrice(taxItem.amount)" class="justify-self-end"></div>
                        </div>
                    </template>
                </div>
            </details>
        </template>
    </div>

</template>
