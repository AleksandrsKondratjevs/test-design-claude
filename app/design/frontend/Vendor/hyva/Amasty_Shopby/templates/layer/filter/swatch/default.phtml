declare(strict_types=1);

use Amasty\Shopby\Block\Navigation\SwatchRenderer;
use Amasty\Shopby\Model\Source\DisplayMode;
use Amasty\ShopbyHyvaCompatibility\ViewModel\ProductListAjax;
use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Framework\Escaper;
use Magento\Swatches\ViewModel\Product\Renderer\Configurable as ConfigurableViewModel;

/** @var Escaper $escaper */
/** @var SwatchRenderer $block */
/** @var ViewModelRegistry $viewModels */

/** @var ConfigurableViewModel $configurableViewModel */
$configurableViewModel = $viewModels->require(ConfigurableViewModel::class);

/** @var ProductListAjax $productListAjax */
$productListAjax = $viewModels->require(ProductListAjax::class);

$swatchData = $block->getSwatchData();
$isSwatchBlock = $block instanceof \Amasty\Shopby\Block\Navigation\State\Swatch;
$filterSetting = $block->getFilterSetting();
$filterCode = $filterSetting ? $escaper->escapeHtml($filterSetting->getAttributeCode()) : '';
$extraClass = $filterSetting ? 'am-filter-items-' . $filterCode : '';
$attributeCode = $escaper->escapeHtml($swatchData['attribute_code']);
$attributeFilter = $block->getFilter() ? $block->getFilter()->getRequestVar() : '';
$displayMode = $filterSetting ? $filterSetting->getDisplayMode() : false;
$displayMode = $displayMode ?: $block->getDisplayModeByAttributeCode($attributeCode);
$showImagesLabel = $displayMode == DisplayMode::MODE_IMAGES_LABELS;
$relNofollow = $filterSetting ? $filterSetting->isAddNofollow() : false;
$showProductQuantities = $filterSetting ? $filterSetting->getShowProductQuantities() : 0;
$expandedMode = $filterSetting ? $filterSetting->getData('is_expanded') : false;
// phpcs:disable Generic.Files.LineLength.TooLong
?>

<?php if ($filterSetting && $showImagesLabel && $filterSetting->isShowSearchBox(count($swatchData['options']))): ?>
    <?= /* @noEscape */ $block->getSearchForm() ?>
<?php endif; ?>
<form class="am-filter relative am-shopby-form swatch-layered <?= $escaper->escapeHtmlAttr($swatchData['attribute_code']) ?> <?= $showImagesLabel ? 'swatch-label-view' : ''; ?>"
      x-data="dataLayeredSwatch_<?= $escaper->escapeJs($swatchData['attribute_code']) ?>()"
      aria-label="<?= $escaper->escapeHtmlAttr($attributeFilter) ?>"
      <?= $attributeFilter ? 'data-amshopby-filter="' . $escaper->escapeHtmlAttr($attributeFilter) . '"' : '' ?>
      <?= $expandedMode ? 'data-amshopby-expanded="' . $escaper->escapeHtmlAttr($expandedMode) . '"' : 'data-amshopby-expanded="0"' ?>
      <?php if ($filterSetting && $block->getEnableOverflowScroll($filterSetting) > 0): ?>
      style="max-height:<?= /* @noEscape */ $block->getOverflowScrollValue($filterSetting) ?>px;"
      <?php endif; ?>>
    <div class="<?= /* @noEscape */ $extraClass ?> swatch-layered clearfix flex flex-wrap gap-2
        <?= /* @noEscape */ $attributeCode ?>
        <?= $showImagesLabel ? 'am-swatch-options swatch-attribute-options swatch-label block' : 'swatch-attribute-options'; ?>"
        data-attribute-code="<?= /* @noEscape */ $attributeCode ?>"
        data-attribute-id="<?= /* @noEscape */ $swatchData['attribute_id'] ?>"
        data-am-js="swatch-options"
        aria-label="<?= $escaper->escapeHtmlAttr($attributeFilter) ?>"
        role="radiogroup"
    >
        <?php foreach ($swatchData['options'] as $option => $label): ?>
            <?php
            $filterItem = $label[SwatchRenderer::VAR_FILTER_ITEM] ?? null;
            $isSelected = $filterItem ? $block->isFilterItemSelected($filterItem) : false;
            $extraSwatchClass = $isSelected ? 'border-container-lighter' : 'border-container-darker';
            $inputType = $filterSetting && $block->isMultiselect($filterSetting) ? 'checkbox' : ($filterSetting && !in_array($filterCode, ['rating', 'stock']) ? 'radio' : null);
            $optionType = $swatchData['swatches'][$option]['type'];
            $optionValue = $swatchData['swatches'][$option]['value'];
            $type = $optionType === SwatchRenderer::SWATCH_TYPE_OPTION_IMAGE ? '3' : $optionType;
            $imageUrl = $optionType === SwatchRenderer::SWATCH_TYPE_OPTION_IMAGE
                ? $optionValue
                : $block->getSwatchPath('swatch_image', $optionValue);
            $swatchThumbPath = $block->getSwatchPath('swatch_thumb', $optionValue);
            $classSwatch = (array_key_exists(SwatchRenderer::VAR_COUNT, $label) && !$label[SwatchRenderer::VAR_COUNT]) ? '-empty-value' : '';
            ?>
            <div class="am-swatch-wrapper item swatch-option-link-layered <?= $escaper->escapeHtmlAttr($classSwatch); ?>
                <?= $filterSetting ? 'p-0.5 pe-2.5 border-2 rounded-xs' : '' ?>
                <?= $isSelected ? 'border-primary' : 'border-primary-alpha-15' ?>
                <?= $type === '0' && $filterSetting ? 'px-2.5' : '' ?>
                "
                data-label="<?= $escaper->escapeHtmlAttr($label['label']) ?>">
                <?php if ($isSwatchBlock): ?>
                <span class="swatch-option-link-layered am-swatch-link flex gap-2 items-center">
                <?php else: ?>
                    <?php if (isset($inputType)): ?>
                        <label>
                            <input class="input hidden"
                                   name="amshopby[<?= /* @noEscape */ $block->getFilter()->getRequestVar() ?>][]"
                                   id="amswatch-id-<?= $escaper->escapeHtmlAttr($label['label']) ?>-<?= $escaper->escapeHtmlAttr($swatchData['attribute_code']) ?>-<?= $escaper->escapeHtmlAttr(uniqid()) ?>"
                                   value="<?= /* @noEscape */ $option ?>"
                                   type="<?= /* @noEscape */ $inputType ?>"
                                   <?= /* @noEscape */ $isSelected ? 'checked' : ''; ?>
                            />
                            <span class="sr-only">
                                <?= $escaper->escapeHtml($label['label']) ?>
                            </span>
                        </label>
                    <?php endif; ?>
                <a href="<?= $escaper->escapeUrl($label['link']) ?>"
                    data-label="<?= $escaper->escapeHtmlAttr($label['label']) ?>"
                    class="
                        swatch-option-link-layered swatch-option cursor-pointer select-none me-0
                        justify-start min-h-[22px] border-none shadow-none font-normal text-black flex gap-2
                        group no-underline items-center
                    <?= ($displayMode === 5) ? 'label-image-view' : '' ?>
                    <?= /* @noEscape */ $showImagesLabel ? 'swatch-attribute-options image-label' : 'swatch-attribute-options'; ?>
                    <?= /* @noEscape */ $isSelected ? 'amshopby-link-selected' : ''; ?>"
                    @click.prevent.stop="window.dispatchEvent(new CustomEvent('amSwatchClick', {
                        detail: {
                            element: $event.currentTarget
                        }
                    }));"
                    :class="{
                       'h-auto' : getSwatchType('<?= /* @noEscape */ (string)$optionType ?>') === 'text'
                    }"
                    <?= $relNofollow ? 'rel="nofollow"' : '' ?>
                >
                <?php endif; ?>
                    <span class="
                            relative inline-block align-middle cursor-pointer rounded-xs
                            <?php if ($type !== '0'): ?>
                                <?= $filterSetting ? 'min-w-6 min-h-6 max-w-6 max-h-6' : 'min-w-4 min-h-4 max-w-4 max-h-4' ?>
                            <?php endif; ?>
                          <?= (string)$type === '0' ? 'h-auto' : '' ?>
                          <?= /* @noEscape */ $extraSwatchClass ?>"
                          :style="getSwatchBackgroundStyle(
                          '<?= /* @noEscape */ $type ?>',
                          '<?= /* @noEscape */ $optionValue ?>',
                          '<?= $escaper->escapeUrl($imageUrl); ?>')"
                          <?php if ($configurableViewModel->getShowSwatchTooltip()): ?>
                          @mouseenter.self="activeTooltipItem = {
                              attribute: '<?= $escaper->escapeJs($optionValue) ?>',
                              type: '<?= $escaper->escapeJs($type) ?>',
                              id: '<?= $escaper->escapeJs($option) ?>',
                              label: '<?= $escaper->escapeJs($label['label']) ?>',
                              thumb: '<?= $escaper->escapeUrl($swatchThumbPath) ?>',
                              value: '<?= $escaper->escapeJs($optionValue) ?>'
                          }; tooltipPositionElement = $event.target;"
                          @mouseleave.self="activeTooltipItem = false; tooltipPositionElement = false;"
                          <?php endif; ?>>
                        <?php if ((string)$type === '0'): ?>
                            <span class="block align-center text-center m-auto label text-base"><?= $escaper->escapeHtml($label['label']) ?></span>
                        <?php else: ?>
                            <span class="sr-only"><?= $escaper->escapeHtml($label['label']) ?></span>
                        <?php endif; ?>
                    </span>
                    <?php if ($showImagesLabel): ?>
                        <span class="swatch-image-label inline-block">
                            <span class="am-shopby-swatch-label flex gap-1">
                                <?php if ((string)$type !== '0'): ?>
                                    <span class="
                                        group-hover:!text-primary transition-colors label m-0 !mb-0 text-base
                                        <?= $filterSetting ? 'font-medium' : 'font-normal' ?>
                                        "
                                    >
                                        <?= $escaper->escapeHtml($label['label']) ?>
                                    </span>
                                <?php endif; ?>
                                <?php if ($filterSetting && $block->isShowProductQuantities($showProductQuantities)): ?>
                                    <?php
                                    $title = ($filterItem->getCount() == 1) ? __('item') : __('items');
                                    ?>
                                    <span class="count text-grey text-sm">
                                        <?= /* @noEscape */ "(" . $filterItem->getCount() . ")"; ?>
                                        <span class="filter-count-label sr-only">
                                            <?= $escaper->escapeHtml($title) ?>
                                        </span>
                                    </span>
                                <?php endif; ?>
                            </span>
                        </span>
                    <?php endif; ?>
                <?php if ($isSwatchBlock): ?>
                </span>
                <?php else: ?>
                </a>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>
    </div>
    <div class="tooltip-wrapper am-navigation-tooltip">
        <?php if ($configurableViewModel->getShowSwatchTooltip()): ?>
            <?= /* @noEscape */ $block->getBlockHtml('product.swatch.tooltip'); ?>
        <?php endif; ?>
    </div>
</form>
<script>
  function dataLayeredSwatch_<?= $escaper->escapeJs($swatchData['attribute_code']) ?>() {
    return deepMerge({}, dataLayeredSwatch())
  }
</script>
