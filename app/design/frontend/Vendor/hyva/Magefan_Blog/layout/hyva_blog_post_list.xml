<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="page.main.title">
            <arguments>
                <argument name="maybe_purged_tailwind_section_classes" xsi:type="string">container my-6 font-bold lg:mt-0 lg:mb-8</argument>
                <argument name="css_class" xsi:type="string">justify-start</argument>
            </arguments>
        </referenceBlock>

        <referenceBlock name="blog.posts.list">
            <block class="Magefan\Blog\Block\Sidebar\Search" name="blog.search"
                template="sidebar/search.phtml">
                <arguments>
                    <argument name="is_sidebar" xsi:type="boolean">false</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>