<?php
/**
 * Blog sidebar categories template
 *
 * @var $block \Magefan\Blog\Block\Sidebar\Categories
 */
?>

<?php $items = $block->getGroupedChilds(); ?>

<?php
/** @var Hyva\Theme\ViewModel\HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(\Hyva\Theme\ViewModel\HeroiconsOutline::class);
?>

<?php if (count($items)) { ?>
<div class="block-categories mb-12">
    <div class="text-h3-sm lg:text-h4 mb-4 md:mb-6">
        <?= $block->escapeHtml(__('Categories')) ?>
    </div>

    <ul class="accordion font-semibold pl-4">
    <?php
        $level = 0;
        $first = true;
        foreach ($items as $item) {
            $newLevel = $item->getLevel();

            if ($level == $newLevel && !$first) {
                echo '</li>';
            }

            if ($level < $newLevel) {
                echo '<ul>';
            }

            if ($level > $newLevel) {
                for ($i = $level; $i > $newLevel; $i--) {
                    echo '</ul></li>';
                }
            }
    ?>
        <li class="<?= ($newLevel > 0) ? 'pl-3' : 'pt-1' ?>">
            <a class="duration-300 no-underline" href="<?= $block->escapeUrl($item->getCategoryUrl()) ?>">
                <?= $block->escapeHtml($item->getTitle()) ?>
            </a>
            <?php if ($block->showPostsCount()) { ?>
                <span class="text-grey ml-1">(<?= $block->escapeHtml($item->getPostsCount()) ?>)</span>
            <?php } ?>
            <?php
            $level = $newLevel;
            $first = false;
        }
    ?>
    </ul>
</div>
<?php } ?>