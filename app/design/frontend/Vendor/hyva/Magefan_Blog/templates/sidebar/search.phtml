/** @var Hyva\Theme\ViewModel\HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(\Hyva\Theme\ViewModel\HeroiconsOutline::class);

$isSidebar = $block->getIsSidebar();
$isVisibleAlways = $block->getVisibleAlways();
?>

<div
    class="
        blog-search mb-8 md:mb-12
        <?php if (!$isVisibleAlways): ?>
        <?= $isSidebar ? 'hidden md:block' : 'md:hidden' ?>
        <?php endif; ?>
    "
>
    <form class="form blog-search relative " id="blog_search_mini_form"
        action="<?= $block->escapeUrl($block->getFormUrl()) ?>"
        method="get"
        onsubmit="goBlogSearch(event);">
        <input id="blog_search"
            type="text"
            name="q"
            value="<?= $block->escapeHtml($block->getQuery()) ?>"
            placeholder="<?= $block->escapeHtml(__('Search posts here...')) ?>"
            class="w-full form-input pe-12 h-12 hover:border-primary focus:border-primary py-[11px] focus:shadow-none"
            maxlength="128" role="combobox"
            aria-haspopup="false"
            aria-autocomplete="both"
            autocomplete="off">
        <div class="w-12 h-12 bg-primary absolute end-0 rounded-e-sm flex justify-center items-center top-0">
            <?= $heroicons->searchHtml('w-5 h-5 text-white') ?>
        </div>
    </form>
</div>
<script type="text/javascript">
    function goBlogSearch(event) {
        var value = document.getElementById('blog_search').value;
        if (value) {
            var a = document.getElementById('blog_search_mini_form').action;
            window.location = a + (('/' != a.charAt(a.length - 1)) ? '/' : '') + encodeURI(value) + '/';
        }
        event.preventDefault();
    }
</script>
