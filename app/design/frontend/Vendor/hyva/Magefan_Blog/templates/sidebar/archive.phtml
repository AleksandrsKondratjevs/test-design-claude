<?php
/**
 * Blog sidebar archive template
 *
 * @var $block \Magefan\Blog\Block\Sidebar\Archive
 */
?>

<?php
    $_months = $block->getMonths();
    $index = 0;
?>
<?php if ($monthsCount = count($_months)) { ?>
<div class="block-archive">
    <div class="text-h3-sm lg:text-h4 mb-4 md:mb-6">
        <?= $escaper->escapeHtml(__('Archive')) ?>
    </div>
    <div class="block-content flex flex-wrap gap-2">
        <?php foreach ($_months as $time) { ?>
            <?php
                $title = $block->getTranslatedDate($time);
                $index++;
            ?>
            <div class="item">
                <a title="<?= $escaper->escapeHtml(__('Archive %1', $title)) ?>"
                   class="archive-item-link duration-300"
                   href="<?= $escaper->escapeUrl($block->getTimeUrl($time)) ?>">
                    <?= $escaper->escapeHtml($title); ?>
                </a>
            </div>
            <?php if ($index != $monthsCount): ?>
                <span class="text-primary-alpha-15">/</span>
            <?php endif; ?>
        <?php } ?>
    </div>
</div>
<?php } ?>

