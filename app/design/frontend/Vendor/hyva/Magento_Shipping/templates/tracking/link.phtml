use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Shipping\Block\Tracking\Link;

/** @var Escaper $escaper */
/** @var Link $block */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

$order = $block->getOrder();
?>
<a href="<?= $escaper->escapeUrl($block->getWindowUrl($order)) ?>" class="no-underline"
   target="_blank" rel="noopener" title="<?= $escaper->escapeHtmlAttr($block->getLabel()) ?>">
    <?= $heroicons->searchHtml('inline-block', 20, 20); ?>
    <span class="inline-block ms-2 underline font-bold">
        <?= $escaper->escapeHtml($block->getLabel()) ?>
    </span>
</a>
