declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HeroiconsOutline $heroicons */
/** @var HyvaCsp $hyvaCsp */

$heroicons = $viewModels->require(HeroiconsOutline::class);
?>

<div class="block <?= $escaper->escapeHtmlAttr($block->getBlockCss()) ?> max-md:mb-4 mb-8 p-0.5 bg-container-darker"
     x-data="initAccountNavigation()"
>
    <button
        type="button"
        class="
            title <?= $escaper->escapeHtmlAttr($block->getBlockCss()) ?>-title
            flex md:hidden w-full justify-between items-center gap-3 p-3.5
        "
        @click="blockOpen = !blockOpen"
        :aria-expanded="blockOpen"
        :aria-disabled="!isMobile"
        :disabled="!isMobile ? '' : null"
    >

        <h4 x-text="currentNavigationTitle">

        </h4>
        <span
            class="md:hidden"
            x-ref="AccountNavigationMobileToggleIcon"
        >
            <?= $heroicons->chevronDownHtml(
                'transition-transform duration-300 ease-in-out transform',
                16,
                16,
                [
                    ':class'      => "{ 'rotate-180': blockOpen }",
                    'aria-hidden' => 'true',
                    'focusable' => 'false'
                ]
            ); ?>
        </span>
    </button>
    <div
        class="grid transition-grid-row grid-rows-[0fr] md:grid-rows-[1fr] duration-200"
        :class="{ 'grid-rows-[1fr]': blockOpen, 'grid-rows-[0fr]': !blockOpen }"
    >
        <div class="overflow-hidden">
            <div class="content <?= $escaper->escapeHtmlAttr($block->getBlockCss()) ?>-content"
                id="<?= $escaper->escapeHtmlAttr($block->getBlockCss()) ?>"
                x-ref="navigationContent"
            >
                <?= $block->getChildHtml() ?>
            </div>
        </div>
    </div>
</div>
<script>
    function initAccountNavigation() {
        return {
            blockOpen: false,
            currentNavigationTitle: '',

            init() {
                this.handleSetTitle();
            },
            handleSetTitle() {
                try {
                    this.currentNavigationTitle = this.$refs.navigationContent.querySelector('.current strong').innerHTML;
                } catch {
                    this.currentNavigationTitle = '<?= $escaper->escapeHtml(__($block->getData('block_title'))) ?>';
                }
            }
        }
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>
