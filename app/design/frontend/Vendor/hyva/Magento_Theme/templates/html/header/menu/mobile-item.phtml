declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

/** @var string[] $item */
$item = $block->getItem();

/** @var int $level */
$level = $block->getLevel() ?: 0;

if (!$item) {
    return '';
}

$menuId = str_replace('-', '_',$item['id']);
$itemClasses = (string) $block->getItemClasses() ?: "flex items-center gap-2 p-4 border-b border-primary-alpha-15 text-black font-normal no-underline";
$itemIconSize = (int) $block->getItemIconSize() ?: 16;
$itemIndent = 'ms-7';
?>

<?php if (!empty($item['childData'])): ?>
    <li data-level="<?= $level ?>" x-data="initMobileSubMenu" x-ref="subMenu">
        <button
            type="button"
            class="w-full justify-between <?= $escaper->escapeHtmlAttr($itemClasses) ?>"
            aria-controls="<?= $escaper->escapeHtml($item['id']) ?>-mobile-menu-panel"
            aria-expanded="false"
            x-ref="openSubMenuBtn"
            :aria-expanded="isOpen"
            :disabled="isOpen"
            @click="open"
        >
            <span class="<?= $level > 0 ? $itemIndent : '' ?>"><?= $escaper->escapeHtml($item['name']) ?></span>
            <span class="btn p-1 bg-transparent text-current">
                <?= $heroicons->chevronRightHtml('rtl:rotate-180', $itemIconSize, $itemIconSize, ['aria-hidden' => 'true']) ?>
            </span>
        </button>
        <ul
            id="<?= $escaper->escapeHtml($item['id']) ?>-mobile-menu-panel"
            class="z-10 absolute inset-0 bg-white overflow-y-auto overscroll-y-contain transition  duration-300 list-none"
            x-show="isOpen"
            x-transition:enter-start="opacity-0 translate-x-1/2 rtl:-translate-x-1/2"
            x-transition:enter-end="opacity-100 translate-x-0"
            x-transition:leave-start="opacity-100 translate-x-0"
            x-transition:leave-end="opacity-0 translate-x-1/2 rtl:-translate-x-1/2"
            @keydown.escape.stop.prevent="close"
        >
            <li data-level="<?= $level + 1 ?>">
                <button
                    type="button"
                    class="w-full bg-container-darker <?= $escaper->escapeHtmlAttr($itemClasses) ?>"
                    @click="close"
                    x-ref="closeSubMenuBtn"
                >
                    <span class="p-1">
                        <?= $heroicons->chevronLeftHtml('rtl:rotate-180', $itemIconSize, $itemIconSize, ['aria-hidden' => 'true']) ?>
                    </span>
                    <?= $escaper->escapeHtml($item['name']) ?>
                </button>
                <a
                    href="<?= $escaper->escapeUrl($item['url']) ?>"
                    class="<?= $escaper->escapeHtmlAttr($itemClasses) ?>"
                >
                    <span class="<?= $escaper->escapeHtmlAttr($itemIndent) ?>">
                        <?= $escaper->escapeHtml(__('See all %1', $item['name'])) ?>
                    </span>
                </a>
            </li>
            <?php foreach ($item['childData'] as $subMenu): ?>
                <?=
                    $block->getLayout()
                    ->createBlock('Magento\Framework\View\Element\Template')
                    ->setTemplate('Magento_Theme::html/header/menu/mobile-item.phtml')
                    ->setData([
                        'item' => $subMenu,
                        'level' => $level + 1,
                        'itemClass' => $itemClasses,
                    ])
                    ->toHtml();
                ?>
            <?php endforeach; ?>
        </ul>
    </li>
<?php else: ?>
    <li data-level="<?= $level ?>">
        <a
            href="<?= $escaper->escapeUrl($item['url']) ?>"
            class="<?= $escaper->escapeHtmlAttr($itemClasses) ?>"
            <?php if(isset($item['category_menu_color'])): ?>
                style="color: <?= $escaper->escapeHtmlAttr($item['category_menu_color']); ?>;"
            <?php endif; ?>
        >
            <span class="<?= $level > 0 ? $itemIndent : '' ?>"><?= $escaper->escapeHtml($item['name']) ?></span>
        </a>
    </li>
<?php endif; ?>
