<script>
    function initHeader() {
        return {
            searchOpen: false,
            cart: {},
            isCartOpen: false,
            isMobile: true,
            // Defined in px
            downScrollThreshold: 300,
            upScrollThreshold: 150,
            headerTagElement: undefined,
            lastScrollPosition: window.scrollY,
            lastScrollDirection: undefined,

            init() {
                this.headerTagElement = document.querySelector('header.page-header');

                this.onChangeMedia(this.$store.device.isDesktop);
                this.handleNotificationHeight();

                this.$watch('$store.device.isDesktop', (isDesktop) => {
                    this.onChangeMedia(isDesktop);
                    this.handleNotificationHeight();
                })

            },
            handleNotificationHeight() {
                this.headerTagElement.style.setProperty('--header-notification-height', `${this.$refs.headerNotification.offsetHeight}px`);
            },
            handleScrollThreshold() {
                const {
                    scrollY
                } = window;

                // Determine if we are scrolling up or down
                const isScrollingDown = this.lastScrollPosition < scrollY;
                const isScrollingUp = this.lastScrollPosition > scrollY;

                if (isScrollingDown && this.lastScrollDirection !== 'down') {
                    this.lastScrollDirection = 'down';
                    this.scrollUpDistance = 0;
                }

                if (isScrollingUp && this.lastScrollDirection !== 'up') {
                    this.lastScrollDirection = 'up';
                    this.scrollDownDistance = 0;
                }

                // If scrolling down and exceeding the down scroll threshold, hide notification
                if (isScrollingDown && scrollY > this.downScrollThreshold && !this.isNotificationHidden) {
                    this.handleHideNotification(true, scrollY);
                    this.lastScrollPosition = scrollY;
                    return;
                }

                // If scrolling up and exceeding the up scroll threshold (100px), show notification again
                if (isScrollingUp && (scrollY < this.lastScrollPosition - this.upScrollThreshold)) {
                    this.handleHideNotification(false, scrollY);
                    this.lastScrollPosition = scrollY;
                    return;
                }

                // Handle the scrolling up or down thresholds with reset behavior
                if (isScrollingDown) {
                    this.scrollDownDistance += scrollY - this.lastScrollPosition;
                    if (this.scrollDownDistance > this.downScrollThreshold) {
                        this.handleHideNotification(true, scrollY);
                    }
                }

                if (isScrollingUp) {
                    this.scrollUpDistance += this.lastScrollPosition - scrollY;
                    if (this.scrollUpDistance > 100) {
                        this.handleHideNotification(false, scrollY);
                    }
                }

                // Update the last scroll position
                this.lastScrollPosition = scrollY;
            },
            handleHideNotification(isHidden, scrollPosition) {
                if (isHidden) {
                    this.headerTagElement.classList.add('page-header-hidden-notification');
                } else {
                    this.headerTagElement.classList.remove('page-header-hidden-notification');
                }

                this.isNotificationHidden = isHidden;
                this.lastScrollPosition = scrollPosition;
            },
            getData(data) {
                if (data.cart) {
                    this.cart = data.cart ?? {};
                }
            },
            cartAriaLabel() {
                return '<?= $escaper->escapeHtml($showMiniCart ? __('Toggle minicart') : __('View cart')) ?>, ' +
                    this.isCartEmpty() ?
                    '<?= $escaper->escapeHtml(__('Cart is empty')) ?>' :
                    hyva.str(
                        'You have %1 product%2 in your cart.',
                        cart.summary_count,
                        cart.summary_count === 1 ? '' : 's'
                    );
            },
            isCartEmpty() {
                return !this.cart.summary_count;
            },
            toggleCart() {
                this.isCartOpen = this.$event.detail?.isOpen ?? true;
                this.$dispatch('toggle-cart', { isOpen: this.isCartOpen });
            },
            onChangeMedia(isDesktop) {
                if (!isDesktop) {
                    this.$refs.searchContainerMobile.appendChild(this.$refs.searchForm);
                } else {
                    const desktopSearchContainer = this.$refs.searchContainerDesktop;
                    if (desktopSearchContainer.firstElementChild) {
                        desktopSearchContainer.replaceChild(this.$refs.searchForm, desktopSearchContainer.firstElementChild);
                    } else {
                        desktopSearchContainer.appendChild(this.$refs.searchForm);
                    }
                }
            }
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initHeader', initHeader);
    }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>

