                                                        title="<?= $escaper->escapeHtmlAttr($itemLevel2['name']) ?>"
                                                        class="level-1 block text-xl no-underline font-bold text-black"
                                                        <?php if(isset($itemLevel2['category_menu_color'])): ?>
                                                            style="--menu-item-color: <?= $escaper->escapeHtmlAttr($itemLevel2['category_menu_color']); ?>;"
                                                        <?php endif; ?>
                                                    >
