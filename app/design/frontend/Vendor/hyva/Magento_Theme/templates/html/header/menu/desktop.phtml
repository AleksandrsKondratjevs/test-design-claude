                                                    </a>

                                                    <ul class="z-10 w-full list-none flex flex-col gap-4 mt-5">
                                                        <?php foreach ($itemLevel2['childData'] as $itemLevel3): ?>
                                                            <li class="level-2 ">
                                                                <a href="<?= $escaper->escapeUrl($itemLevel3['url']) ?>"
                                                                    title="<?= $escaper->escapeHtmlAttr($itemLevel3['name']) ?>"
                                                                    class="level-2 block font-medium no-underline text-black"
                                                                    <?php if(isset($itemLevel3['category_menu_color'])): ?>
                                                                        style="--menu-item-color: <?= $escaper->escapeHtmlAttr($itemLevel3['category_menu_color']); ?>;"
                                                                    <?php endif; ?>
                                                                >
