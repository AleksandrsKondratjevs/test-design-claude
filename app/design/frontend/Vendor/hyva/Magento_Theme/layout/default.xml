<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="hyva_form_validation"/>

    <body>
        <move element="topmenu_mobile" destination="header-content" after="-"/>
        <move element="topmenu_desktop" destination="header-content" after="-"/>

        <referenceBlock name="topmenu_mobile">
            <block name="topmenu_mobile_item" template="Magento_Theme::html/header/menu/mobile-item.phtml"/>
            <arguments>
                <argument name="max_level" xsi:type="number">4</argument> <!-- Max Menu depth to show -->
                <argument name="show_settings_nav" xsi:type="boolean">true</argument> <!-- Show Settings Nav (true/false) -->
            </arguments>
        </referenceBlock>

        <referenceBlock name="messages">
            <arguments>
                <argument name="display_mode" xsi:type="string">default</argument> <!-- Notification appearance (default/blank/tag) -->
                <argument name="show_icon" xsi:type="boolean">true</argument>  <!-- Show icon (true/false) -->
            </arguments>
        </referenceBlock>

        <referenceContainer name="footer">
            <container name="footer.wrapper" htmlTag="div">
                <block class="Magento\Cms\Block\Block" name="footer-content">
                    <arguments>
                        <argument name="block_id" xsi:type="string">footer-sample-1</argument>
                    </arguments>
                </block>
            </container>
        </referenceContainer>

        <referenceBlock name="header-content">
            <block class="Magento\Cms\Block\Block" name="header-notification">
                <arguments>
                    <argument name="block_id" xsi:type="string">notification-sample-1</argument>
                </arguments>
            </block>

            <block name="header.currency-language-switcher" template="Magento_Theme::html/header/currency-language-switcher.phtml" />
        </referenceBlock>

        <move element="page.messages" destination="header-content" />

        <referenceBlock name="script-alpine-js">
            <block name="alpine-plugin-htmldialog" template="Magento_Theme::page/js/plugins/htmldialog.phtml"/>
        </referenceBlock>
    </body>
</page>