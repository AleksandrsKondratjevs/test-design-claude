declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Hyva\Theme\ViewModel\ProductCompare;
use Hyva\Theme\ViewModel\ProductPrice;
use Hyva\Theme\ViewModel\Wishlist;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Amasty\XsearchHyvaCompatibility\ViewModel\SearchPopup;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var Wishlist $wishlistViewModel */
$wishlistViewModel = $viewModels->require(Wishlist::class);
/** @var ProductCompare $compareViewModel */
$compareViewModel = $viewModels->require(ProductCompare::class);
/** @var HeroiconsOutline $heroIcons */
$heroIcons = $viewModels->require(HeroiconsOutline::class);
/** @var ProductPrice $productPrice */
$productPrice = $viewModels->require(ProductPrice::class);
/** @var SearchPopup $popupViewModel */
$popupViewModel = $viewModels->require(SearchPopup::class);
// phpcs:disable Generic.Files.LineLength.TooLong
?>

<div class="item flex-col product product-item card card-interactive flex round-none shadow-none border-none"
     :class="{
        'flex-1': !config.isGridView,
        'md:flex-row w-full': config.isGridView && (isFullWidthSearch || isDefaultSearchInput || searchPopupWidth > 900),
        'w-full md:w-auto md:max-w-md': !config.isGridView && (!isFullWidthSearch || !isDefaultSearchInput || searchPopupWidth <= 900)
     }">
    <a :href="getProductUrl(product)"
       class="photo product-item-photo relative flex justify-center align-center"
       tabindex="-1"
       <?php if ($popupViewModel->isProductLabelEnabled()): ?>x-ref="amLabelParent"<?php endif; ?>
       :class="{ 'md:mb-0 md:mr-5': config.isGridView }"
    >
        <img class="object-contain w-full aspect-square"
             :class="{
                'md:max-w-48': config.isGridView
             }"
             :src="getProductImageUrl(product)"
             :alt="product.small_image.label"
             <?php if ($popupViewModel->isProductLabelEnabled()): ?>x-ref="amLabelImgParent"<?php endif; ?>
             width="272"
             height="272"
        />

        <?php if ($wishlistViewModel->isEnabled()): ?>
            <template x-if="!product.am_hide_price_wishlist">
                <button aria-label="<?= $escaper->escapeHtmlAttr(__('Add to Wish List')) ?>"
                        @click.prevent="addToWishlist(product)"
                        class="absolute top-0 right-0 p-3 bg-white rounded-bl-sm text-black hover:text-primary">
                    <?= $heroIcons->heartHtml("w-5 h-5", 20, 20) ?>
                </button>
            </template>
        <?php endif ?>

        <?php if ($popupViewModel->isProductLabelEnabled()): ?>
            <?= /* @noEscape */ $block->fetchView($block->getTemplateFile('Amasty_ProductLabelAdvancedSearch::components/product-wrapper.phtml')) ?>
        <?php endif; ?>
    </a>

    <div
        class="product-info max-md:flex max-md:flex-col max-md:mt-3 grow max-md:gap-3"
        :class="{ 'flex flex-col gap-3 md:mt-3': !config.isGridView, 'md:grid md:grid-cols-1 lg:grid-cols-[1fr_272px] md:gap-x-5': config.isGridView }"
    >
        <div>
            <div
                class="mb-0.5 flex gap-4 text-left"
                :class="{'gap-4 justify-between': !config.isGridView, 'gap-1 flex-col': config.isGridView }"
            >
                <a class="product-item-link action link no-underline" :href="getProductUrl(product)">
                    <span x-html="product.name" class="text-black font-bold text-base"></span>
                </a>
                <template x-if="config.isShowSku">
                    <div class="text-sm font-normal">
                        <span><?= $escaper->escapeHtml(__('SKU')) ?>:</span>
                        <span x-html="product.sku"></span>
                    </div>
                </template>
            </div>
            <div>
                <template x-if="config.isProductReviewsBlockEnabled">
                    <?= /* @noEscape */ $block->fetchView($block->getTemplateFile('Amasty_XsearchHyvaCompatibility::header-search/components/rating.phtml')) ?>
                </template>
            </div>
            <template x-if="truncateWithDots(product.short_description.html, config.shortDescriptionLength).length">
                <div class="items-center justify-center text-left mt-3"
                x-html="truncateWithDots(product.short_description.html, config.shortDescriptionLength)"
                ></div>
            </template>
        </div>
        <div class="flex flex-col gap-3" :class="{'justify-between': config.isGridView }">
            <div :class="{'lg:text-right': config.isGridView }">
                <?= /** @noEscape */ $popupViewModel->fetchPriceView(
                    'header-search/components/price.phtml'
                ); ?>
            </div>
            <div class="product-actions flex items-center gap-y-4 gap-x-2">
                <template x-if="config.isProductAddToCartBlockEnabled && product.is_salable && !product.am_hide_price_addtocart && !product.hide_price_newAddToCart">
                    <button type="button"
                            class="action-addtocart btn btn-primary w-full"
                            x-on:click.prevent="addToCart(product, $event)"
                    >
                        <?= $escaper->escapeHtml(__('Add to Cart')) ?>
                    </button>
                </template>

                <template x-if="product.hide_price_newAddToCart">
                    <div x-html="product.hide_price_newAddToCart"></div>
                </template>

                <template x-if="config.isProductAddToCartBlockEnabled && !product.is_salable">
                    <div class="action-addtocart justify-center text-sm text-left">
                        <span class="inline-block w-3 h-3 bg-red-500 rounded-full flex-shrink-0"></span>
                        <span class="text-sm text-gray-700 text-left"><?= $escaper->escapeHtml(__('Out of stock')) ?></span>
                    </div>
                </template>

                <?php if ($compareViewModel->showInProductList()): ?>
                    <template x-if="!product.am_hide_price_compare">
                        <button @click.prevent="addToCompare(product)"
                                aria-label="<?= $escaper->escapeHtmlAttr(__('Add to Compare')) ?>"
                                class="btn btn-secondary p-3">
                            <?= $heroIcons->switchHorizontalHtml("w-5 h-5", 20, 20, ['aria-hidden' => 'true']) ?>
                        </button>
                    </template>
                <?php endif ?>
            </div>
        </div>
    </div>
</div>
