declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */
?>
<div class="w-full mb-8">
    <h4 class="mb-4 px-4" x-text="sections.page.title"></h4>

    <template x-for="(item, index) in sections.page.items" :key="index">
        <div>
            <a class="w-full text-base font-normal no-underline block text-black hover:bg-black hover:text-white transition-colors py-3.5 px-4"
               :href="`${BASE_URL + item.url}`">
                <span x-html="item.title" class="font-semibold"></span>
            </a>
            <span class="text-black block my-1 px-4"
                  x-html="item.description"></span>
        </div>
    </template>
</div>
