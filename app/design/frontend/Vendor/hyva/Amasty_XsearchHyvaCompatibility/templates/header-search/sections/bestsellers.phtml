declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
// phpcs:disable Generic.Files.LineLength.TooLong
?>

<div class="w-full mb-8">
    <a href="#amasty_xsearch_bestsellers_slider_end"
       class="action skip sr-only focus:not-sr-only focus:absolute focus:z-30 focus:bg-white">
        <?= $escaper->escapeHtml(__('Press to skip carousel')) ?>
    </a>
    <h4 class="text-lg font-bold mb-2" x-text="sections.bestsellers.title"></h4>
    <div class="w-full carousel" x-ref="bestsellersContainer">
        <div class="relative w-full overflow-x-hidden carousel"
             x-intersect:enter.once="slider.bestsellers.init($refs)"
             x-on:resize.window.debounce="slider.bestsellers.onResize()">
            <div class="relative flex flex-nowrap w-full overflow-x-auto carousel-slides snap"
                 @scroll.debounce="slider.bestsellers.calcActive()"
                 id="bestsellerSlider">
                <template x-for="(product, index) in sections.bestsellers.items" :key="index">
                    <div class="carousel-slide flex flex-shrink-0 w-full js_slide md:w-1/2 lg:w-1/3 xl:w-1/4 h-carousel-product-item">
                        <?= /** @noEscape  */ $block->fetchView(
                            $block->getTemplateFile(
                                'Amasty_XsearchHyvaCompatibility::header-search/components/product-slider-item.phtml'
                            )
                        ) ?>
                    </div>
                </template>
            </div>
            <div class="carousel-controls">
                <div style="min-height: 65px">
                    <template x-if="slider.bestsellers.itemCount > slider.bestsellers.pageSize">
                        <div class="flex items-center justify-center py-4">
                            <button
                                aria-label="<?= $escaper->escapeHtml(__('Previous')) ?>"
                                class="mr-4 text-black rounded-full flex-none"
                                :class="{
                                    'opacity-25 pointer-events-none': slider.bestsellers.active === 0
                                }"
                                @click="slider.bestsellers.prev()"
                                @keydown.enter.prevent.stop="slider.bestsellers.prev()"
                                @keydown.space.prevent.stop="slider.bestsellers.prev()"
                            >
                                <?= $heroicons->chevronLeftHtml("w-5 h-5", 25, 25) ?>
                            </button>

                            <div class="flex flex-wrap w-full md:w-auto justify-center">
                                <template x-for="(item, index) in slider.bestsellers.itemCount" :key="index">
                                    <span
                                        role="button"
                                        tabindex="0"
                                        class="flex-shrink-0 block w-3 h-3 m-1 bg-black rounded-full shadow cursor-pointer"
                                        :class="{
                                            'bg-black/100': slider.bestsellers.isActive(index),
                                            'bg-black/25': !slider.bestsellers.isActive(index),
                                            'hidden': (slider.bestsellers.pageSize !== 1 && !!(index % slider.bestsellers.pageSize))
                                        }"
                                        :aria-label="'<?= $escaper->escapeHtml(__('Go to item')) ?> ' + (index + 1)"
                                        @click="slider.bestsellers.scrollTo(index)"
                                        @keydown.enter.prevent.stop="slider.bestsellers.scrollTo(index)"
                                        @keydown.space.prevent.stop="slider.bestsellers.scrollTo(index)"
                                    ></span>
                                </template>
                            </div>

                            <button
                                aria-label="<?= $escaper->escapeHtml(__('Next')) ?>"
                                class="ml-4 text-black rounded-full flex-none"
                                :class="{
                                    'opacity-25 pointer-events-none':
                                        slider.bestsellers.active >= slider.bestsellers.itemCount - slider.bestsellers.pageSize
                                }"
                                @click="slider.bestsellers.next()"
                                @keydown.enter.prevent.stop="slider.bestsellers.next()"
                                @keydown.space.prevent.stop="slider.bestsellers.next()"
                            >
                                <?= $heroicons->chevronRightHtml("w-5 h-5", 25, 25) ?>
                            </button>
                        </div>
                    </template>
                </div>
            </div>
            <span id="amasty_xsearch_bestsellers_slider_end" tabindex="-1"></span>
        </div>
    </div>
</div>
