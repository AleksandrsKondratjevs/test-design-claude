$storeName = $storeConfig->getStoreConfig('general/store_information/name');
?>
<div id="header"
     class="relative z-30 w-full bg-white"
>
    <div class="container flex flex-wrap items-center w-full max-md:py-2.5 py-6 mx-auto mt-0 justify-between">
        <div class="flex gap-10">
            <!--Logo-->
            <?= $block->getChildHtml('logo'); ?>

            <?php if ($storeName): ?>
                <div class="flex items-center gap-2 max-md:hidden font-bold">
                    <?= $heroicons->shieldCheckHtml('', 24, 24) ?>
                    <?= __('Shop safely at %1', $storeName) ?>
                </div>
            <?php endif; ?>
        </div>

        <?= $block->getChildHtml('header-customer-support') ?>
    </div>

    <!--Authentication Pop-Up-->
    <?= $block->getChildHtml('authentication-popup'); ?>
</div>

