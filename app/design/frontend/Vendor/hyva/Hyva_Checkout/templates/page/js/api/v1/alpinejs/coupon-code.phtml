declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;

/** @var HyvaCsp $hyvaCsp */

?>
<script>
    function hyvaCheckoutCouponCode() {
        return hyva.createBooleanObject('visible', false, {
            couponCode: this.$wire.entangle('couponCode'),
            couponHits: this.$wire.entangle('couponHits'),

            rotateClass() {
                return {
                    'transform rotate-180': this.visible()
                }
            },
            visibleClass() {
                return {
                    'grid-rows-[1fr]': this.visible(),
                    'grid-rows-[0fr]': !this.visible()
                }
            },
            inputHasCouponCodeClass() {
                return {
                    'has-coupon': this.couponCode,
                    'invalid': this.couponHits !== 0
                }
            }
        })
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('hyvaCheckoutCouponCode', hyvaCheckoutCouponCode)
    }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>
