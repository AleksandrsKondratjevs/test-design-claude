declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;

/** @var HyvaCsp $hyvaCsp */

?>
<script>
    function hyvaCheckoutStreet() {
        return {
            streetArray: [],
            showStreetsArray: [],

            init() {
                Array.from(this.$el.children).forEach((element) => {
                    if (element.dataset?.street) {
                        const street = element.dataset?.street;
                        this.streetArray.push(street);
                    }
                });
            },

            addStreet() {
                this.$refs[`street-${this.streetArray[0]}`].classList.add('!block');
                this.showStreetsArray.push(this.streetArray[0]);
                this.streetArray = this.streetArray.slice(1);
            },

            streetsAvailable() {
                return this.streetArray.length;
            }
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('hyvaCheckoutStreet', hyvaCheckoutStreet)
    }, {
        once: true
    })
</script>
<?php $hyvaCsp->registerInlineScript() ?>