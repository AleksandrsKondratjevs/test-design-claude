declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Checkout\ViewModel\Checkout\Formatter as FormatterViewModel;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var FormatterViewModel $formatterViewModel */

$formatterViewModel = $viewModels->require(FormatterViewModel::class);

$quoteItem = $block->getData('quote_item');
$options = $quoteItem['options'] ?? null;
?>
<?php if ($options): ?>
    <div class="flex gap-x-6 gap-y-1 flex-wrap">
        <?php foreach ($options as $option): ?>
            <p class="flex gap-1 text-xs">
                <?php $optionLabel = $option['label']; ?>
                <span class="font-bold">
                    <?= $escaper->escapeHtml($optionLabel); ?><?= __(':') ?>
                </span>
                
                <?php $optionValue = $option['value']; ?>
                <span class="text-grey">
                    <?= /* @noEscape */ $optionValue; ?>
                </span>
            </p>
        <?php endforeach ?>
    </div>
<?php endif ?>
