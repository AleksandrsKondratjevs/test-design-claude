declare(strict_types=1);

use Hyva\Checkout\Model\Form\AbstractEntityFormElement;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */

/** @var AbstractEntityFormElement $element */
$element = $block->getData('element');

// Get all form element attributes
$attributes = $element->getAttributes();
?>
<label
    for="<?= $escaper->escapeHtmlAttr($attributes['id'] ?? $element->getId()) ?>"
    class="<?= $escaper->escapeHtmlAttr($element->renderClass(['label'], 'label')) ?>"
>
    <span>
        <?= $escaper->escapeHtml(__($element->getLabel())) ?>
    </span>
</label>
