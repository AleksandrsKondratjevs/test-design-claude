use Magento\Framework\Escaper;
use Magento\Wishlist\Block\Customer\Wishlist\Item\Column\Info;
use Magento\Wishlist\Model\Item;

/** @var Info $block */
/** @var Escaper $escaper */

/** @var Item $item */
$item = $block->getItem();
$product = $item->getProduct();
?>
<span class="product-item-name">
    <a href="<?= $escaper->escapeUrl($block->getProductUrl($item)) ?>"
       title="<?= $escaper->escapeHtmlAttr($product->getName()) ?>" class="product-item-link text-black no-underline">
        <?= $escaper->escapeHtml($product->getName()) ?>
    </a>
</span>
