use Magento\Framework\Escaper;
use Magento\Wishlist\Block\Customer\Wishlist\Items;

/** @var Escaper $escaper */
/** @var Items $block */
$columns = $block->getColumns();
?>

<div class="products-grid wishlist">
    <?php if (count($block->getItems())): ?>
    <ol class="product-items grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 list-none gap-4">
        <?php foreach ($block->getItems() as $item): ?>
            <li data-row="product-item" class="product-item flex"
                id="item_<?= $escaper->escapeHtmlAttr($item->getId()) ?>">
                <div class="product-item-info card card-interactive flex flex-col w-full h-full" data-container="product-grid">
                    <?php foreach ($columns as $column): ?>
                        <?= $column->setItem($item)->toHtml();?>
                    <?php endforeach; ?>
                </div>
            </li>
        <?php endforeach; ?>
    </ol>
    <?php else: ?>
        <div class="message info empty">
            <span><?= $escaper->escapeHtml(__('This Wish List has no Items')) ?></span>
        </div>
    <?php endif; ?>
</div>

<?php foreach ($columns as $column): ?>
    <?= $column->getAdditionalHtml() ?>
<?php endforeach; ?>
