declare(strict_types=1);

use Hyva\Theme\Model\LocaleFormatter;
use Magento\Catalog\Block\Product\ProductList\Toolbar;
use Magento\Framework\Escaper;

/** @var Toolbar $block */
/** @var Escaper $escaper */
/** @var LocaleFormatter $localeFormatter */
?>
<p class="toolbar-total order-3 md:order-1 text-grey" id="toolbar-total" data-total="<?= $escaper->escapeHtmlAttr($localeFormatter->formatNumber($block->getTotalNum())) ?>">
        <?= $escaper->escapeHtml(
            __(
                '%1 items found', $localeFormatter->formatNumber($block->getTotalNum())
            )
        ) ?>
</p>
