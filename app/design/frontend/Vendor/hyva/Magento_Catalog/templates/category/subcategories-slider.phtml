use Hyva\Theme\ViewModel\HyvaCsp;
use Scandiweb\Theme\ViewModel\SubcategorySlider;

/** @var HyvaCsp $hyvaCsp */

/** @var SubcategorySlider $subcategorySliderViewModel */
$subcategorySliderViewModel = $viewModels->require(SubcategorySlider::class);

$uniqueId = '_' . uniqid('');

$category = $block->getCurrentCategory();
$subcategories = $subcategorySliderViewModel->getSubcategoriesForSlider($category);

if (!count($subcategories)) {
    return null;
}

$sliderCountMobile = 2.5;
$sliderCountTablet = 4;
$sliderCountDesktop = 6;
?>

<script>
    function initSubcategories<?= $uniqueId ?>() {
        return {
            isLoading: true,

            init() {
                const swiperElement = this.$refs.categoriesWrapper;

                const swiperOptions = {
                    slidesPerView: 'auto',
                    spaceBetween: 16,
                    mousewheel: {
                        forceToAxis: true
                    },
                    navigation: {
                        nextEl: '.swiper-button-next<?= $uniqueId ?>',
                        prevEl: '.swiper-button-prev<?= $uniqueId ?>',
                    },
                    pagination: {
                        el: '.swiper-pagination<?= $uniqueId ?>',
                        type: 'bullets',
                        dynamicBullets: true,
                        dynamicMainBullets: 4,
                        clickable: true,
                    },
                    breakpoints: {
                        1024: {
                            spaceBetween: 16,
                            slidesPerView: 5,
                        },
                        1240: {
                            spaceBetween: 16,
                            slidesPerView: 6
                        }
                    }
                };

                initSwiperSlider(this.$refs.categoriesWrapper, swiperOptions);
            }
        }
    }
</script>
<?php $hyvaCsp->registerInlineScript() ?>

<div x-data="initSubcategories<?= $uniqueId ?>" class="overflow-visible pt-16 container" id="<?= $escaper->escapeHtmlAttr($uniqueId) ?>">
    <div class="relative">
        <div class="swiper swiper-horizontal overflow-hidden" x-ref="categoriesWrapper">
            <div class="swiper-wrapper flex">
                <?php foreach ($subcategories as $subcategory): ?>
                    <?php
                    $title = $subcategory->getName();
                    $image = $subcategory->getCategoryThumbnail();
                    $url = $subcategory->getUrl();
                    ?>
                    <a href="<?= $escaper->escapeUrl($url) ?>" class="!flex lg:max-w-48 flex-col gap-2 md:gap-4 swiper-slide items-center max-lg:max-w-32 no-underline text-black">
                        <img class="aspect-square w-full size-32 lg:min-h-48 lg:min-w-48" width="128" height="128" src="<?= $escaper->escapeHtmlAttr($image) ?>" alt="<?= $escaper->escapeHtmlAttr($title) ?>">
                        <span class="w-full text-center text-sm md:text-xl font-bold">
                            <?= $escaper->escapeHtml($title) ?>
                        </span>
                    </a>
                <?php endforeach; ?>
            </div>
        </div>
        <?=
        $this->getLayout()
            ->createBlock('Magento\Framework\View\Element\Template')
            ->setTemplate('Scandiweb_ContentTypes::carousel-nav.phtml')
            ->setData('is_show_arrows', true)
            ->setData('pagination', 'dots')
            ->setData('pagination_container_class', 'pb-0! max-h-11')
            ->setData('arrows_container_class', 'max-lg:-bottom-[32px]')
            ->setData('unique_id', $uniqueId)
            ->toHtml();
        ?>
    </div>
</div>
<?= $this->getLayout()
    ->createBlock('Magento\Framework\View\Element\Template')
    ->setTemplate('Scandiweb_ContentTypes::style/slider-initial-styling.phtml')
    ->setData('slider_count_mobile', $sliderCountMobile)
    ->setData('slider_count_tablet', $sliderCountTablet)
    ->setData('slider_count_desktop', $sliderCountDesktop)
    ->setData('unique_id', $uniqueId)
    ->toHtml(); ?>