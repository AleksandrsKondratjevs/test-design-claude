<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="main.content" htmlClass="page-main category-page-main">
        </referenceContainer>

        <move element="breadcrumbs" destination="category.main" before="page.main.title" />

        <referenceContainer name="category.product.addto.wishlist" remove="false" />

        <move element="page.main.title" destination="category.main" before="category.description"/>
        <move element="category.view.container" destination="columns.top" after="breadcrumbs" />

        <referenceBlock name="page.main.title">
            <arguments>
                <argument name="css_class" xsi:type="string">justify-start lg:pe-0! m-0! mb-0</argument>
            </arguments>
        </referenceBlock>

        <referenceBlock name="breadcrumbs">
            <arguments>
                <argument name="container_css_class" xsi:type="string">lg:pe-0!</argument>
            </arguments>
        </referenceBlock>

        <referenceContainer name="category.view.container" htmlId="category-view-container" htmlClass="category-view container">
            <block class="Magento\Catalog\Block\Category\View" name="category.main" template="Magento_Catalog::category/main.phtml">
                <block class="Magento\Catalog\Block\Category\View" name="category.image" template="Magento_Catalog::category/image.phtml">
                    <arguments>
                        <argument name="image" xsi:type="object">Magento\Catalog\ViewModel\Category\Image</argument>
                        <argument name="output" xsi:type="object">Magento\Catalog\ViewModel\Category\Output</argument>
                    </arguments>
                </block>
                <block class="Magento\Catalog\Block\Category\View" name="category.description" template="Magento_Catalog::category/description.phtml"/>
                <block class="Magento\Catalog\Block\Category\View" name="category.cms" template="Magento_Catalog::category/cms.phtml"/>
                <block class="Magento\Catalog\Block\Category\View" name="category.subcategories.slider" template="Magento_Catalog::category/subcategories-slider.phtml"/>
            </block>
        </referenceContainer>

        <container name="category.cms.container">
            <block class="Magento\Catalog\Block\Category\View" name="category.cms" template="Magento_Catalog::category/cms.phtml"/>
        </container>

        <move element="category.cms.container" destination="main.content" before="footer"/>
    </body>
</page>
