use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Sales\Block\Order\Creditmemo\Items;

/** @var Escaper $escaper */
/** @var Items $block */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

$order = $block->getOrder();
?>
<div class="flex flex-col gap-0.5 mt-0.5">
    <?php foreach ($order->getCreditmemosCollection() as $creditmemo): ?>
        <div class="account-card mt-5 first-of-type:mt-0">
            <div class="order-title flex flex-wrap justify-between items-center gap-4">
                <h4>
                    <?= $escaper->escapeHtml(__('Refund #')) ?>
                    <?= $escaper->escapeHtml($creditmemo->getIncrementId()) ?>
                </h4>
                <a href="<?= $escaper->escapeUrl($block->getPrintCreditmemoUrl($creditmemo)) ?>"
                    target="_blank"
                    class="no-underline"
                    rel="noopener">
                    <?= $heroicons->printerHtml('inline-block', 20, 20); ?>
                    <span class="inline-block ms-2 underline font-bold">
                        <?= $escaper->escapeHtml(__('Print Refund')) ?>
                    </span>
                </a>
            </div>

            <?= $block->getCommentsHtml($creditmemo) ?>

            <div class="order-items creditmemo my-4">
                <div class="hidden lg:grid grid-cols-7 text-sm mt-4 gap-4 pb-2 px-3 font-bold">
                    <div class="col-span-2"><?= $escaper->escapeHtml(__('Product Name')) ?></div>
                    <div><?= $escaper->escapeHtml(__('Price')) ?></div>
                    <div><?= $escaper->escapeHtml(__('Qty')) ?></div>
                    <div class="text-right"><?= $escaper->escapeHtml(__('Subtotal')) ?></div>
                    <div class="text-right"><?= $escaper->escapeHtml(__('Discount')) ?></div>
                    <div class="text-right"><?= $escaper->escapeHtml(__('Row Total')) ?></div>
                </div>
                <?php $items = $creditmemo->getAllItems(); ?>
                <?php foreach ($items as $item): ?>
                    <?php if (!$item->getOrderItem()->getParentItem()): ?>
                        <div class="px-3 py-2 even:bg-white rounded-xs">
                            <?= $block->getItemHtml($item) ?>
                        </div>
                    <?php endif; ?>
                <?php endforeach; ?>
            </div>
        </div>
        <?= $block->getTotalsHtml($creditmemo) ?>
    <?php endforeach; ?>
</div>
