use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Framework\Escaper;
use Magento\Sales\Block\Order\Items;
use Magento\Shipping\Helper\Data as ShippingHelper;

// phpcs:disable Magento2.Templates.ThisInTemplate.FoundThis
// phpcs:disable Magento2.Templates.ThisInTemplate.FoundHelper

/** @var Items $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

$order = $block->getOrder();
$shippingHelper = $this->helper(ShippingHelper::class);
$index = 0;
?>
<?php foreach ($order->getShipmentsCollection() as $shipment): ?>
    <div class="account-card <?= $index ? 'mt-6' : '' ?>">
        <?php $tracks = $shipment->getTracksCollection(); ?>
        <div class="order-title flex flex-wrap justify-between lg:items-center gap-4">
            <h4>
                <?= $escaper->escapeHtml(__('Shipment #')) ?>
                <?= $escaper->escapeHtml($shipment->getIncrementId()) ?>
            </h4>
            <div class="flex gap-4">
                <a href="<?= $escaper->escapeUrl($block->getUrl('*/*/printShipment', ['shipment_id' => $shipment->getId()])) ?>"
                class="no-underline"
                target="_blank"
                rel="noopener">
                    <?= $heroicons->printerHtml('inline-block', 20, 20); ?>
                    <span class="inline-block ms-1 underline"><?= $escaper->escapeHtml(__('Print Shipment')) ?></span>
                </a>
                <?php if ($tracks->count()): ?>
                    <a href="<?= $escaper->escapeUrl($shippingHelper->getTrackingPopupUrlBySalesModel($shipment)) ?>"
                    target="_blank" rel="noopener" title="<?= $escaper->escapeHtml(__('Track Shipment')) ?>"
                    class="no-underline lg:ps-4 lg:rounded-s border-primary-alpha-15">
                        <?= $heroicons->searchHtml('inline-block', 20, 20); ?>
                        <span class="inline-block ms-1 underline"><?= $escaper->escapeHtml(__('Track Shipment')) ?></span>
                    </a>
                <?php endif; ?>
            </div>
        </div>

        <?php if ($tracks->count()): ?>
            <div class="my-4 text-sm flex gap-1">
                <p><?= $escaper->escapeHtml(__('Tracking Number(s):')) ?></p>
                <div class="tracking-content">
                    <?php
                    $i    = 1;
                    $size = $tracks->count();
                    foreach ($tracks as $track): ?>
                        <?php if ($track->isCustom()): ?>
                            <?= $escaper->escapeHtml($track->getNumber()) ?>
                        <?php else: ?>
                            <a href="<?= $escaper->escapeUrl($shippingHelper->getTrackingPopupUrlBySalesModel($track)) ?>"
                            target="_blank" rel="noopener"
                            class="inline-block underline"><span><?= $escaper->escapeHtml($track->getNumber()) ?></span>
                            </a>
                        <?php endif; ?>
                        <?php if ($i != $size): ?>, <?php endif; ?>
                        <?php $i++;
                    endforeach; ?>
                </div>
            </div>
        <?php endif; ?>

        <div class="order-items shipment my-4">
            <div class="hidden lg:grid grid-cols-3 text-sm mt-4 gap-4 pb-2 px-3 font-bold">
                <div class="col-span-2">
                    <?= $escaper->escapeHtml(__('Product Name')) ?>
                </div>
                <div><?= $escaper->escapeHtml(__('Qty Shipped')) ?></div>
            </div>
            <?php $items = $shipment->getAllItems(); ?>
            <?php foreach ($items as $item): ?>
                <?php if (!$item->getOrderItem()->getParentItem()): ?>
                    <div class="px-3 py-2 even:bg-white rounded-xs">
                        <?= $block->getItemHtml($item) ?>
                    </div>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    </div>
    <?php $index++; ?>
<?php endforeach; ?>
