declare(strict_types=1);

use Magento\Framework\View\Element\Template;
use Hyva\Theme\ViewModel\HyvaCsp;

/** @var Template $block */
/** @var HyvaCsp $hyvaCsp */

?>
<script>
    'use strict';

    (() => {
        document.querySelectorAll('[data-content-type="tabs"], [data-content-type="scandiweb_tabs_with_image"]').forEach(tab => {
            const defaultActiveTab = parseInt(tab.dataset.activeTab) || 0;

            tab.querySelectorAll('.tab-header').forEach((tabHeader, index) => {
                const tabLink = tabHeader.querySelector('a');
                const tabId = tabLink.getAttribute('href').replace('#', '');
                tabHeader.setAttribute(':class', `{ 'active': tab === '${tabId}' }`);
                tabLink.setAttribute('x-on:click.prevent', `tab = '${tabId}';
                 const nextTick = $nextTick(() => $dispatch('page-builder-tab-activate', {tab: document.getElementById('${tabId}'), nextTick}))`);

                if (index === defaultActiveTab) {
                    tab.setAttribute('x-data', `{ tab: '${tabId}' }`);
                }
            });
        });

        document.querySelectorAll('[data-content-type="tab-item"], [data-content-type="scandiweb_tab_with_image_item"]').forEach((tabItem, index) => {
            if (index) {
                tabItem.setAttribute('x-cloak', '');
            }

            tabItem.setAttribute('x-show', `tab === '${tabItem.id}'`);
            tabItem.classList.add('tabs-initialized');
        });
    })();

    'use strict';

    const initTabsSlider = (elements) => {
        const initSlider = (slider) => {
            const sliderWrapper = slider.querySelector('.tabs-navigation');

            const sliderContainer = document.createElement('div');
            sliderContainer.classList.add('swiper', 'tabs-slider', 'overflow-hidden');

            if (sliderWrapper) {
                sliderWrapper.parentNode.insertBefore(sliderContainer, sliderWrapper.nextSibling);
            } else {
                slider.prepend(sliderContainer);
            }

            const tabsNavigation = slider.querySelector('.tabs-navigation');
            tabsNavigation.classList.add('swiper-wrapper', 'tabs-initialized');

            sliderContainer.appendChild(tabsNavigation);
            sliderContainer.insertAdjacentHTML(
                'beforeend',
                '<?= $escaper->escapeJs(
                        $this->getLayout()
                            ->createBlock('Magento\Framework\View\Element\Template')
                            ->setTemplate('Scandiweb_ContentTypes::carousel-nav.phtml')
                            ->setData('is_show_arrows', false)
                            ->setData('pagination', 'progressbar')
                            ->setData('pagination_container_class', 'max-lg:mt-4!')
                            ->toHtml()
                    ) ?>'
            );

            const pagination = sliderContainer.querySelector('.swiper-scrollbar');

            const slides = slider.querySelectorAll('[data-element="headers"]');
            slides.forEach(slide => {
                slide.classList.add('swiper-slide');
            });

            const swiperOptions = {
                slidesPerView: 'auto',
                spaceBetween: 12,
                scrollbar: {
                    el: pagination,
                    draggable: true,
                },
            };

            initSwiperSlider(sliderContainer, swiperOptions);
        };
        elements.forEach(element => {
            initSlider(element);
        });
    }

    document.addEventListener('alpine:init', () => {
        const carouselElements = document.querySelectorAll(
            '[data-content-type="tabs"], [data-content-type="scandiweb_tabs_with_image"]'
        );

        if (carouselElements.length > 0) {
            initTabsSlider(carouselElements);
        }
    });
</script>
<?php $hyvaCsp->registerInlineScript() ?>
