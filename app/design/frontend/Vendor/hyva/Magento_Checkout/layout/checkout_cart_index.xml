<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <move element="cart.discount" destination="cart.summary" after="checkout.cart.shipping"/>
        <referenceContainer name="cart.summary.before" htmlClass="cart-summary-actions"/>
        <referenceContainer name="cart.summary">
            <block name="cart.summary.cms_block" template="Magento_Checkout::php-cart/cart-summary-cms-blocks.phtml" after="checkout.cart.methods.bottom" />
        </referenceContainer>
    </body>
</page>
