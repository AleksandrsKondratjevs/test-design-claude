declare(strict_types=1);

// phpcs:disable Generic.WhiteSpace.ScopeIndent
// phpcs:disable Magento2.Files.LineLength.MaxExceeded

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\ProductStockItem;
use Hyva\Theme\ViewModel\HeroiconsOutline;
use Magento\Checkout\Block\Cart\Item\Renderer;
use Magento\Framework\Escaper;

/** @var Renderer $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroicons */
$heroicons = $viewModels->require(HeroiconsOutline::class);

$item = $block->getItem();
$product = $item->getProduct();
$isVisibleProduct = $product->isVisibleInSiteVisibility();

$stockItemViewModel = $viewModels->require(ProductStockItem::class);
$qty = $stockItemViewModel->isQtyDecimal($product)
    ? $block->getQty()
    : (int) $block->getQty();

$isBundleProduct = $product->getTypeId() === 'bundle';

?>
<tbody class="cart item border-2 border-b-0 last-of-type:border-b-2 border-container-darker"
       <?php foreach ($block->getData('cart_item_data_attributes') as $attribute => $include): ?>
           <?php if ($include): ?>
               <?php /** Append data-* attributes based on layout XML arguments */ ?>
               <?= $escaper->escapeHtml(sprintf('data-%s', $attribute)); ?>="<?= $escaper->escapeHtmlAttr($item->getData($attribute)); ?>"
           <?php endif; ?>
       <?php endforeach; ?>
>
    <tr
        class="
            item-info align-top text-left md:text-right grid grid-cols-2 gap-y-3 px-3.5 py-4
            [grid-template-areas:'details_details''bundleOptions_bundleOptions''price_subtotal''qty_actions'] md:table-row
        "
    >
        <td data-th="<?= $escaper->escapeHtml(__('Item')) ?>" colspan="2" class="col item md:p-4 [grid-area:details] flex gap-3 text-left w-full md:w-auto">
            <?php if ($block->hasProductUrl()): ?>
                <a href="<?= $escaper->escapeUrl($block->getProductUrl()) ?>"
                   title="<?= $escaper->escapeHtmlAttr($block->getProductName()) ?>"
                   tabindex="-1"
                   class="product-item-photo shrink-0">
            <?php else: ?>
                <span class="product-item-photo shrink-0">
            <?php endif;?>
            <?= $block->getImage($block->getProductForThumbnail(), 'cart_page_product_thumbnail')
                ->setTemplate('Magento_Catalog::product/image.phtml')
                ->toHtml() ?>
            <?php if ($block->hasProductUrl()): ?>
                </a>
            <?php else: ?>
                </span>
            <?php endif; ?>
            <div class="product-item-details grow">
                <div class="flex flex-col gap-1">
                    <strong class="product-item-name break-all">
                        <?php if ($block->hasProductUrl()): ?>
                            <a class="text-black no-underline" href="<?= $escaper->escapeUrl($block->getProductUrl()) ?>"><?= $escaper->escapeHtml($block->getProductName()) ?></a>
                        <?php else: ?>
                            <?= $escaper->escapeHtml($block->getProductName()) ?>
                        <?php endif; ?>
                    </strong>
                    <span class="text-xs text-grey"><?= $escaper->escapeHtml($product->getSku()) ?></span>
                </div>
                <?php if ($options = $block->getOptionList()): ?>
                    <div
                        class="
                            item-options flex flex-col gap-2 product-bundle-options
                            md:gap-x-6 break-all mt-2.5 text-sm
                            <?= $isBundleProduct ? 'max-md:hidden md:flex-col' : 'flex-wrap md:flex-row' ?>
                        "
                    >
                        <?php foreach ($options as $option): ?>
                            <div class="flex gap-1 <?= !$isBundleProduct ?: 'flex-col' ?>">
                                <?php $formatedOptionValue = $block->getFormatedOptionValue($option) ?>
                                <span class="font-bold float-left clear-left text-xs"><?= $escaper->escapeHtml($option['label']) ?>:</span>
                                <span class="float-left text-xs text-grey">
                                    <?php if (isset($formatedOptionValue['full_view'])): ?>
                                            <?= $escaper->escapeHtml($formatedOptionValue['full_view']) ?>
                                        <?php else: ?>
                                            <?= $escaper->escapeHtml($formatedOptionValue['value'], ['span', 'a']) ?>
                                    <?php endif; ?>
                                </span>
                            </div>
                        <?php endforeach; ?>
                    </div>
                <?php endif;?>
                <?php if ($messages = $block->getMessages()): ?>
                    <?php foreach ($messages as $message): ?>
                        <div class= "cart item message <?= $escaper->escapeHtmlAttr($message['type']) ?>">
                            <div><?= $escaper->escapeHtml($message['text']) ?></div>
                        </div>
                    <?php endforeach; ?>
                <?php endif; ?>
                <?php $addInfoBlock = $block->getProductAdditionalInformationBlock(); ?>
                <?php if ($addInfoBlock): ?>
                    <?= $addInfoBlock->setItem($item)->toHtml() ?>
                <?php endif;?>
            </div>
        </td>

        <!-- Duplicate for bundle products due to position of options on mobile -->
        <?php if($options && $isBundleProduct): ?>
            <td class="[grid-area:bundleOptions] md:hidden product-bundle-options">
                <?php if ($options = $block->getOptionList()): ?>
                    <div
                        class="
                            item-options flex flex-col gap-2
                            md:gap-x-6 break-all text-sm md:flex-col
                        "
                    >
                        <?php foreach ($options as $option): ?>
                            <div class="flex gap-1 <?= !$isBundleProduct ?: 'flex-col' ?>">
                                <?php $formatedOptionValue = $block->getFormatedOptionValue($option) ?>
                                <span class="font-bold float-left clear-left text-xs"><?= $escaper->escapeHtml($option['label']) ?>:</span>
                                <span class="text-xs text-grey flex">
                                    <?php if (isset($formatedOptionValue['full_view'])): ?>
                                            <?= $escaper->escapeHtml($formatedOptionValue['full_view']) ?>
                                        <?php else: ?>
                                            <?= $escaper->escapeHtml($formatedOptionValue['value'], ['span', 'a']) ?>
                                    <?php endif; ?>
                                </span>
                            </div>
                        <?php endforeach; ?>
                    </div>
                <?php endif;?>
            </td>
        <?php endif; ?>


        <td class="col price md:p-4 block w-full md:w-auto md:table-cell md:text-center [grid-area:price]">
            <span class="md:hidden text-xs font-bold mb-1 block">
                <?= $escaper->escapeHtml(__('Price')) ?>
            </span>
            <?= $block->getUnitPriceHtml($item) ?>
        </td>

        <td class="col qty md:p-4 block w-full md:w-auto md:table-cell [grid-area:qty]">
            <div class="field qty" x-data="{ qty: <?= $escaper->escapeHtmlAttr($qty) ?> }">
                <div class="control qty flex gap-2 md:justify-center">
                    <label for="cart-<?= $escaper->escapeHtmlAttr($item->getId()) ?>-qty" class="sr-only">
                        <span class="label"><?= $escaper->escapeHtml(__('Qty')) ?></span>
                    </label>
                    <button @click.prevent="qty--" class="btn btn-secondary p-1.5" :disabled="qty <= 0">
                        <?= $heroicons->minusHtml("w-5 h-5", 20, 20) ?>
                    </button>
                    <input
                            id="cart-<?= $escaper->escapeHtmlAttr($item->getId()) ?>-qty"
                            name="cart[<?= $escaper->escapeHtmlAttr($item->getId()) ?>][qty]"
                            value="<?= $escaper->escapeHtmlAttr($qty) ?>"
                            :value="qty"
                            type="number"
                            class="w-9 border-none bg-transparent p-0 text-center ring-0! outline-hidden! appearance-none font-bold"
                            x-model.number="qty"
                            size="4"
                            step="any"
                            title="<?= $escaper->escapeHtmlAttr(__('Qty')) ?>"
                            required
                            min="0"
                            data-role="cart-item-qty">
                    </label>
                    <button @click.prevent="qty++" class="btn btn-secondary p-1.5">
                        <?= $heroicons->plusHtml("w-5 h-5", 20, 20) ?>
                    </button>
                </div>
            </div>
        </td>

        <td class="col subtotal text-right md:p-4 block w-full md:w-auto md:table-cell [grid-area:subtotal]">
            <span class="md:hidden text-xs font-bold mb-1 block">
                <?= $escaper->escapeHtml(__('Subtotal')) ?>
            </span>
            <?= $block->getRowTotalHtml($item) ?>
        </td>

        <td class="col [grid-area:actions] md:hidden">
            <div class="flex items-center justify-end gap-3 md:p-4">
                <?= /* @noEscape */ $block->getActions($item) ?>
            </div>
        </td>
    </tr>
    <tr class="item-actions hidden md:table-row">
        <td colspan="4">
            <div class="flex items-center justify-end gap-3 p-4">
                <?= /* @noEscape */ $block->getActions($item) ?>
            </div>
        </td>
    </tr>
</tbody>
