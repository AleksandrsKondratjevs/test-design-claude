<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_PageBuilder:etc/content_type.xsd">
    <type name="scandiweb_tabs_with_image"
          label="Tabs With Image"
          component="Magento_PageBuilder/js/content-type-collection"
          preview_component="Scandiweb_ContentTypes/js/content-type/tabs-with-image/preview"
          master_component="Magento_PageBuilder/js/content-type/master-collection"
          form="pagebuilder_scandiweb_tabs_with_image_form"
          menu_section="layout"
          icon="icon-pagebuilder-tabs"
          sortOrder="25"
          translate="label">
        <breakpoints>
            <breakpoint name="mobile">
                <form>pagebuilder_scandiweb_tabs_with_image_mobile_form</form>
            </breakpoint>
        </breakpoints>
        <parents default_policy="deny">
            <parent name="root-container" policy="allow"/>
            <parent name="row" policy="allow"/>
            <parent name="column" policy="allow"/>
        </parents>
        <children default_policy="deny">
            <child name="scandiweb_tab_with_image_item" policy="allow"/>
        </children>
        <appearances>
            <appearance name="default"
                        default="true"
                        preview_template="Scandiweb_ContentTypes/content-type/tabs-with-image/default/preview"
                        master_template="Scandiweb_ContentTypes/content-type/tabs-with-image/default/master"
                        reader="Magento_PageBuilder/js/master-format/read/configurable">
                <elements>
                    <element name="main">
                        <style name="display" source="display" converter="Magento_PageBuilder/js/converter/style/display" preview_converter="Magento_PageBuilder/js/converter/style/preview/display"/>
                        <style name="margins" storage_key="margins_and_padding" reader="Magento_PageBuilder/js/property/margins" converter="Magento_PageBuilder/js/converter/style/margins"/>
                        <style name="padding" storage_key="margins_and_padding" reader="Magento_PageBuilder/js/property/paddings" converter="Magento_PageBuilder/js/converter/style/paddings"/>
                        <attribute name="block_title" source="data-block-title"/>
                        <attribute name="block_subtitle" source="data-block-subtitle"/>
                        <attribute name="tab_color" source="data-background_color" />
                        <attribute name="name" source="data-content-type"/>
                        <attribute name="appearance" source="data-appearance"/>
                        <attribute name="default_active" source="data-active-tab"/>
                        <css name="css_classes">
                            <filter>
                                <class source="tab-align-left"/>
                                <class source="tab-align-center"/>
                                <class source="tab-align-right"/>
                            </filter>
                        </css>
                    </element>
                    <element name="background">
                        <style name="tab_color" source="background_color" />
                    </element>
                    <element name="headers">
                        <style name="border" source="border_style" converter="Magento_PageBuilder/js/converter/style/border-style"/>
                        <style name="border_radius" source="border_radius" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="border_color" source="border_color"/>
                        <style name="border_width" source="border_width" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                    </element>
                    <element name="navigation">
                        <style name="navigation_alignment" source="text_align"/>
                    </element>
                    <element name="content">
                        <style name="border" source="border_style" converter="Magento_PageBuilder/js/converter/style/border-style"/>
                        <style name="text_align" source="text_align"/>
                        <style name="border_color" source="border_color"/>
                        <style name="border_width" source="border_width" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="border_radius" source="border_radius" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="min_height" source="min_height" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="tab_color" source="background_color" />
                    </element>
                </elements>
                <converters>
                    <converter name="header_alignment_class" component="Magento_PageBuilder/js/content-type/tabs/mass-converter/header-alignment">
                        <config>
                            <item name="navigation_alignment_variable" value="navigation_alignment"/>
                        </config>
                    </converter>
                </converters>
            </appearance>
            <appearance name="full-width"
                        default="false"
                        preview_template="Scandiweb_ContentTypes/content-type/tabs-with-image/full-width/preview"
                        master_template="Scandiweb_ContentTypes/content-type/tabs-with-image/full-width/master"
                        reader="Magento_PageBuilder/js/master-format/read/configurable">
                <elements>
                    <element name="main">
                        <style name="display" source="display" converter="Magento_PageBuilder/js/converter/style/display" preview_converter="Magento_PageBuilder/js/converter/style/preview/display"/>
                        <style name="margins" storage_key="margins_and_padding" reader="Magento_PageBuilder/js/property/margins" converter="Magento_PageBuilder/js/converter/style/margins"/>
                        <style name="padding" storage_key="margins_and_padding" reader="Magento_PageBuilder/js/property/paddings" converter="Magento_PageBuilder/js/converter/style/paddings"/>
                        <attribute name="block_title" source="data-block-title"/>
                        <attribute name="block_subtitle" source="data-block-subtitle"/>
                        <attribute name="tab_color" source="data-background_color" />
                        <attribute name="name" source="data-content-type"/>
                        <attribute name="appearance" source="data-appearance"/>
                        <attribute name="default_active" source="data-active-tab"/>
                        <css name="css_classes">
                            <filter>
                                <class source="tab-align-left"/>
                                <class source="tab-align-center"/>
                                <class source="tab-align-right"/>
                            </filter>
                        </css>
                    </element>
                    <element name="background">
                        <style name="tab_color" source="background_color" />
                    </element>
                    <element name="headers">
                        <style name="border" source="border_style" converter="Magento_PageBuilder/js/converter/style/border-style"/>
                        <style name="border_radius" source="border_radius" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="border_color" source="border_color"/>
                        <style name="border_width" source="border_width" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                    </element>
                    <element name="navigation">
                        <style name="navigation_alignment" source="text_align"/>
                    </element>
                    <element name="content">
                        <style name="border" source="border_style" converter="Magento_PageBuilder/js/converter/style/border-style"/>
                        <style name="text_align" source="text_align"/>
                        <style name="border_color" source="border_color"/>
                        <style name="border_width" source="border_width" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="border_radius" source="border_radius" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="min_height" source="min_height" converter="Magento_PageBuilder/js/converter/style/remove-px"/>
                        <style name="tab_color" source="background_color" />
                    </element>
                </elements>
                <converters>
                    <converter name="header_alignment_class" component="Magento_PageBuilder/js/content-type/tabs/mass-converter/header-alignment">
                        <config>
                            <item name="navigation_alignment_variable" value="navigation_alignment"/>
                        </config>
                    </converter>
                </converters>
            </appearance>
        </appearances>
    </type>
</config>
