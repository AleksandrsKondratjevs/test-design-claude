<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_PageBuilder:etc/content_type.xsd">
    <type name="scandiweb_promo" label="Promo"
        backend_block="Scandiweb\ContentTypes\Block\ContentTypes\Promo"
        menu_section="scandiweb_components" component="Magento_PageBuilder/js/content-type"
        preview_component="Scandiweb_ContentTypes/js/content-type/promo/preview"
        master_component="Magento_PageBuilder/js/content-type/master"
        form="pagebuilder_scandiweb_promo_form" sortOrder="6" translate="label">
        <children default_policy="deny" />
        <parents default_policy="deny">
            <parent name="row" policy="allow" />
            <parent name="column" policy="allow" />
            <parent name="tab-item" policy="allow" />
            <parent name="scandiweb_tab_with_image_item" policy="allow" />
        </parents>
        <appearances>
            <appearance name="default" default="true"
                preview_template="Scandiweb_ContentTypes/content-type/promo/default/preview"
                master_template="Scandiweb_ContentTypes/content-type/promo/default/master"
                reader="Magento_PageBuilder/js/master-format/read/configurable">
                <elements>
                    <element name="main">
                        <attribute name="name" source="data-content-type" />
                        <attribute name="appearance" source="data-appearance" />
                        <attribute name="appearance_type" source="appearance_type" />
                        <attribute name="block_title" source="block_title" />
                        <attribute name="block_sub_title" source="block_sub_title" />
                        <attribute name="cta_type" source="cta_type" />
                        <attribute name="promo_card_color" source="promo_card_color" />
                        <attribute name="is_show_all_enabled" source="is_show_all_enabled" />
                        <attribute name="show_all_url" source="show_all_url" converter="Scandiweb_ContentTypes/js/converter/attribute/object"/>
                        <attribute name="slider_infinitive" source="slider_infinitive" />
                        <attribute name="slider_pagination" source="slider_pagination" />
                        <attribute name="slider_show_arrows" source="slider_show_arrows" />
                        <attribute name="slider_count_mobile" source="slider_count_mobile" />
                        <attribute name="slider_count_tablet" source="slider_count_tablet" />
                        <attribute name="slider_count_desktop" source="slider_count_desktop" />
                        <attribute name="grid_columns_mobile" source="grid_columns_mobile" />
                        <attribute name="grid_columns_tablet" source="grid_columns_tablet" />
                        <attribute name="grid_columns_desktop" source="grid_columns_desktop" />
                        <html name="html" />
                        <attribute name="sections" source="data-sections"
                            converter="Scandiweb_ContentTypes/js/converter/attribute/object" />
                    </element>
                </elements>
                <converters>
                    <converter
                        component="Scandiweb_ContentTypes/js/content-type/promo/mass-converter/block-directive"
                        name="block_directive">
                        <config>
                            <item name="html_variable" value="html" />
                        </config>
                    </converter>
                </converters>
            </appearance>
            <appearance name="vertical" default="true"
                preview_template="Scandiweb_ContentTypes/content-type/promo/default/preview"
                master_template="Scandiweb_ContentTypes/content-type/promo/default/master"
                reader="Magento_PageBuilder/js/master-format/read/configurable">
                <elements>
                    <element name="main">
                        <attribute name="name" source="data-content-type" />
                        <attribute name="appearance" source="data-appearance" />
                        <attribute name="appearance_type" source="appearance_type" />
                        <attribute name="block_title" source="block_title" />
                        <attribute name="block_sub_title" source="block_sub_title" />
                        <attribute name="cta_type" source="cta_type" />
                        <attribute name="promo_card_color" source="promo_card_color" />
                        <attribute name="is_show_all_enabled" source="is_show_all_enabled" />
                        <attribute name="show_all_url" source="show_all_url" converter="Scandiweb_ContentTypes/js/converter/attribute/object" />
                        <attribute name="slider_infinitive" source="slider_infinitive" />
                        <attribute name="slider_show_pagination" source="slider_show_pagination" />
                        <attribute name="slider_pagination_type_progressbar"
                            source="slider_pagination_type_progressbar" />
                        <attribute name="slider_show_arrows" source="slider_show_arrows" />
                        <attribute name="slider_count_mobile" source="slider_count_mobile" />
                        <attribute name="slider_count_tablet" source="slider_count_tablet" />
                        <attribute name="slider_count_desktop" source="slider_count_desktop" />
                        <attribute name="grid_columns_mobile" source="grid_columns_mobile" />
                        <attribute name="grid_columns_tablet" source="grid_columns_tablet" />
                        <attribute name="grid_columns_desktop" source="grid_columns_desktop" />
                        <html name="html" />
                        <attribute name="sections" source="data-sections"
                            converter="Scandiweb_ContentTypes/js/converter/attribute/object" />
                    </element>
                </elements>
                <converters>
                    <converter
                        component="Scandiweb_ContentTypes/js/content-type/promo/mass-converter/block-directive"
                        name="block_directive">
                        <config>
                            <item name="html_variable" value="html" />
                        </config>
                    </converter>
                </converters>
            </appearance>
            <appearance name="full_image" default="true"
                preview_template="Scandiweb_ContentTypes/content-type/promo/default/preview"
                master_template="Scandiweb_ContentTypes/content-type/promo/default/master"
                reader="Magento_PageBuilder/js/master-format/read/configurable">
                <elements>
                    <element name="main">
                        <attribute name="name" source="data-content-type" />
                        <attribute name="appearance" source="data-appearance" />
                        <attribute name="appearance_type" source="appearance_type" />
                        <attribute name="block_title" source="block_title" />
                        <attribute name="block_sub_title" source="block_sub_title" />
                        <attribute name="cta_type" source="cta_type" />
                        <attribute name="promo_card_color" source="promo_card_color" />
                        <attribute name="is_show_all_enabled" source="is_show_all_enabled" />
                        <attribute name="show_all_url" source="show_all_url" converter="Scandiweb_ContentTypes/js/converter/attribute/object" />
                        <attribute name="slider_infinitive" source="slider_infinitive" />
                        <attribute name="slider_show_pagination" source="slider_show_pagination" />
                        <attribute name="slider_pagination_type_progressbar"
                            source="slider_pagination_type_progressbar" />
                        <attribute name="slider_show_arrows" source="slider_show_arrows" />
                        <attribute name="slider_count_mobile" source="slider_count_mobile" />
                        <attribute name="slider_count_tablet" source="slider_count_tablet" />
                        <attribute name="slider_count_desktop" source="slider_count_desktop" />
                        <attribute name="grid_columns_mobile" source="grid_columns_mobile" />
                        <attribute name="grid_columns_tablet" source="grid_columns_tablet" />
                        <attribute name="grid_columns_desktop" source="grid_columns_desktop" />
                        <html name="html" />
                        <attribute name="sections" source="data-sections"
                            converter="Scandiweb_ContentTypes/js/converter/attribute/object" />
                    </element>
                </elements>
                <converters>
                    <converter
                        component="Scandiweb_ContentTypes/js/content-type/promo/mass-converter/block-directive"
                        name="block_directive">
                        <config>
                            <item name="html_variable" value="html" />
                        </config>
                    </converter>
                </converters>
            </appearance>
        </appearances>
    </type>
</config>
