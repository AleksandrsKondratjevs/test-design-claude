<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd"
    extends="pagebuilder_base_form">
    <fieldset name="appearance_fieldset" sortOrder="10"
        component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <field name="block_title" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Title</label>
                <dataType>text</dataType>
                <dataScope>block_title</dataScope>
            </settings>
        </field>
        <field name="block_sub_title" sortOrder="21" formElement="input">
            <settings>
                <label translate="true">Subtitle</label>
                <dataType>text</dataType>
                <dataScope>block_sub_title</dataScope>
            </settings>
        </field>
        <field name="is_show_all_enabled" sortOrder="81" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Enable Show all button</label>
                <dataType>boolean</dataType>
                <dataScope>is_show_all_enabled</dataScope>
                <notice translate="true">Enabling this setting will show button which will redirect to selected tab url</notice>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="show_all_button_text" sortOrder="82" formElement="input">
            <settings>
                <label translate="true">Show All Button Text</label>
                <dataType>text</dataType>
                <dataScope>show_all_button_text</dataScope>
            </settings>
        </field>
        <urlInput name="show_all_button_url" sortOrder="83"
            template="Magento_PageBuilder/form/element/url-input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Show All Button URL</label>
                <dataScope>show_all_button_url</dataScope>
                <urlTypes class="Magento\Ui\Model\UrlInput\LinksConfigProvider" />
                <validation>
                    <rule name="validate-message-no-link" xsi:type="boolean">true</rule>
                    <rule name="validate-message-no-widget" xsi:type="boolean">true</rule>
                </validation>
                <imports>
                    <link name="validation.validate-message-no-link">${$.parentName}.content:value</link>
                    <link name="validation.validate-message-no-widget">${$.parentName}.content:value</link>
                </imports>
            </settings>
        </urlInput>
    </fieldset>
    <fieldset name="settings" sortOrder="30">
        <settings>
            <label translate="true">Grid Settings</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="grid_columns_mobile" sortOrder="90" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">2</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Mobile Columns</label>
                <dataScope>grid_columns_mobile</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="grid_columns_tablet" sortOrder="100" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">4</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Tablet Columns</label>
                <dataScope>grid_columns_tablet</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="grid_columns_desktop" sortOrder="110" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">4</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Desktop Columns</label>
                <dataScope>grid_columns_desktop</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>