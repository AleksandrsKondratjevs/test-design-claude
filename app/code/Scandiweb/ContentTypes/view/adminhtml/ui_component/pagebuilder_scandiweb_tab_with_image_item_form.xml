<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_tab_item_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_scandiweb_tab_with_image_item_form.pagebuilder_scandiweb_tab_with_image_item_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Tab</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_scandiweb_tab_with_image_item_form.pagebuilder_scandiweb_tab_with_image_item_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_scandiweb_tab_with_image_item_form</namespace>
    </settings>
    <dataSource name="pagebuilder_scandiweb_tab_with_image_item_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_scandiweb_tab_with_image_item_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="20">
        <settings>
            <label/>
        </settings>
        <field name="tab_name" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Tab Name</label>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="min_height" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Minimum Height</label>
                <addAfter translate="true">px</addAfter>
                <additionalClasses>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                </validation>
            </settings>
        </field>
        <field name="justify_content" sortOrder="30" formElement="select" component="Magento_PageBuilder/js/form/element/visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">flex-start</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Vertical Alignment</label>
                <notice translate="true">Vertical alignment controls how the child blocks of this container will be positioned. Set minimum height in order to use vertical alignment.</notice>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\PageBuilder\Model\Source\VerticalAlignment"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="tab_image" formElement="imageUploader" sortOrder="40">
            <settings>
                <label translate="true">Tab image</label>
                <componentType>imageUploader</componentType>
                <dataScope>tab_image</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg gif png</allowedExtensions>
                        <maxFileSize>4194304</maxFileSize>
                        <uploaderConfig>
                            <param xsi:type="string" name="url">pagebuilder/contenttype/image_upload</param>
                        </uploaderConfig>
                        <previewTmpl>Magento_PageBuilder/form/element/uploader/preview</previewTmpl>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
    </fieldset>
</form>
