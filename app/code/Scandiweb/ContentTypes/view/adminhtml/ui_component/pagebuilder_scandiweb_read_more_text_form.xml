<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_scandiweb_read_more_text_form.pagebuilder_scandiweb_read_more_text_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Text</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_scandiweb_read_more_text_form.pagebuilder_scandiweb_read_more_text_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_scandiweb_read_more_text_form</namespace>
    </settings>
    <dataSource name="pagebuilder_scandiweb_read_more_text_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_scandiweb_read_more_text_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="appearance_fieldset" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Appearance</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceText" />
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="general" sortOrder="20">
        <settings>
            <label/>
        </settings>
        <field name="content" sortOrder="10" formElement="wysiwyg">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">page</item>
                    <item name="wysiwygConfigData" xsi:type="array">
                        <item name="is_pagebuilder_enabled" xsi:type="boolean">false</item>
                        <item name="toggle_button" xsi:type="boolean">false</item>
                    </item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <label/>
                <dataScope>content</dataScope>
            </settings>
            <formElements>
                <wysiwyg>
                    <settings>
                        <wysiwyg>true</wysiwyg>
                    </settings>
                </wysiwyg>
            </formElements>
        </field>
        <field name="truncate_desktop" sortOrder="20" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Truncate on Desktop</label>
                <dataType>boolean</dataType>
                <dataScope>truncate_desktop</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="truncate_desktop_lines" sortOrder="30" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">line-clamp-4</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">never</item>
                    </item>
                </item>
            </argument>
            <settings>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = truncate_desktop:value</link>
                </imports>
                <dataType>text</dataType>
                <label translate="true">Truncrate on Desktop after line</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-7</item>
                                <item name="label" xsi:type="string" translate="true">7</item>
                            </option>
                            <option name="7" xsi:type="array">
                                <item name="value" xsi:type="string">md:line-clamp-8</item>
                                <item name="label" xsi:type="string" translate="true">8</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="truncate_mobile" sortOrder="40" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Truncate on Mobile</label>
                <dataType>boolean</dataType>
                <dataScope>truncate_mobile</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="truncate_mobile_lines" sortOrder="50" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">max-md:line-clamp-4</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">never</item>
                    </item>
                </item>
            </argument>
            <settings>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = truncate_mobile:value</link>
                </imports>
                <dataType>text</dataType>
                <label translate="true">Truncrate on Mobile after line</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-7</item>
                                <item name="label" xsi:type="string" translate="true">7</item>
                            </option>
                            <option name="7" xsi:type="array">
                                <item name="value" xsi:type="string">max-md:line-clamp-8</item>
                                <item name="label" xsi:type="string" translate="true">8</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
