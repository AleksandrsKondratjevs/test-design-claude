<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <dataScope>data</dataScope>
        <namespace>scandiweb_base_grid_slider_form</namespace>
        <buttons>
            <button name="save"
                class="Magento\PageBuilder\Block\Adminhtml\ContentType\Edit\SaveButton" />
            <button name="close"
                class="Magento\PageBuilder\Block\Adminhtml\ContentType\Edit\ModalCloseButton" />
        </buttons>
    </settings>
    <fieldset name="block_appearance" sortOrder="20">
        <settings>
            <label translate="true">Appearance</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>
        <field name="appearance_type" sortOrder="0" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Appearance</label>
                <dataScope>appearance_type</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">slider</item>
                                <item name="label" xsi:type="string" translate="true">Slider</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">grid</item>
                                <item name="label" xsi:type="string" translate="true">Grid</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="slider_infinitive" sortOrder="10" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">false</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Infinitive</label>
                <dataType>boolean</dataType>
                <dataScope>slider_infinitive</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="slider_pagination" sortOrder="20" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">dots</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Pagination</label>
                <dataScope>slider_pagination</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">dots</item>
                                <item name="label" xsi:type="string" translate="true">Dots</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">progressbar</item>
                                <item name="label" xsi:type="string" translate="true">Progressbar</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">none</item>
                                <item name="label" xsi:type="string" translate="true">None</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="slider_show_arrows" sortOrder="40" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Show arrows</label>
                <dataType>boolean</dataType>
                <dataScope>slider_show_arrows</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="slider_count_mobile" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">1.2</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataScope>slider_count_mobile</dataScope>
                <label translate="true">Slides Count on Mobile</label>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                </validation>
            </settings>
        </field>
        <field name="slider_count_tablet" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">3</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Slides Count on Tablet</label>
                <dataScope>slider_count_tablet</dataScope>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                </validation>
            </settings>
        </field>
        <field name="slider_count_desktop" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">4</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">grid</item>
                    </item>
                </item>
            </argument>
            <settings>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <label translate="true">Slides Count on Desktop</label>
                <dataScope>slider_count_desktop</dataScope>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                </validation>
            </settings>
        </field>
        <field name="grid_columns_mobile" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">2</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">slider</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Mobile Columns</label>
                <dataScope>grid_columns_mobile</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="grid_columns_tablet" sortOrder="60" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">3</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">slider</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Tablet Columns</label>
                <dataScope>grid_columns_tablet</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="grid_columns_desktop" sortOrder="70" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">4</item>
                    <item name="disabledValues" xsi:type="array">
                        <item name="none" xsi:type="string">slider</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Desktop Columns</label>
                <dataScope>grid_columns_desktop</dataScope>
                <imports>
                    <link name="setDisabled">ns = ${ $.ns }, index = appearance_type:value</link>
                </imports>
                <additionalClasses>
                    <class name="admin__field-conditional-hide">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">1</item>
                                <item name="label" xsi:type="string" translate="true">1</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">2</item>
                                <item name="label" xsi:type="string" translate="true">2</item>
                            </option>
                            <option name="3" xsi:type="array">
                                <item name="value" xsi:type="string">3</item>
                                <item name="label" xsi:type="string" translate="true">3</item>
                            </option>
                            <option name="4" xsi:type="array">
                                <item name="value" xsi:type="string">4</item>
                                <item name="label" xsi:type="string" translate="true">4</item>
                            </option>
                            <option name="5" xsi:type="array">
                                <item name="value" xsi:type="string">5</item>
                                <item name="label" xsi:type="string" translate="true">5</item>
                            </option>
                            <option name="6" xsi:type="array">
                                <item name="value" xsi:type="string">6</item>
                                <item name="label" xsi:type="string" translate="true">6</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>