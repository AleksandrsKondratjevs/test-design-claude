<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <fieldset name="general" sortOrder="20">
        <field name="block_title" sortOrder="0" formElement="input">
            <settings>
                <label translate="true">Title</label>
                <dataType>text</dataType>
                <dataScope>block_title</dataScope>
            </settings>
        </field>
        <field name="block_subtitle" sortOrder="5" formElement="input">
            <settings>
                <label translate="true">Subtitle</label>
                <dataType>text</dataType>
                <dataScope>block_subtitle</dataScope>
            </settings>
        </field>
        <field name="min_height" sortOrder="30" formElement="input">
            <settings>
                <label translate="true">Minimum Height</label>
                <additionalClasses>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <addAfter>px</addAfter>
                <dataType>text</dataType>
                <dataScope>min_height</dataScope>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
    </fieldset>
</form>
