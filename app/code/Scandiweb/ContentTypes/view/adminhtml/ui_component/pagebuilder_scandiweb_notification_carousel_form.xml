<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" 
extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_scandiweb_notification_carousel_form.pagebuilder_scandiweb_notification_carousel_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Scandiweb Notification Carousel</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_scandiweb_notification_carousel_form.pagebuilder_scandiweb_notification_carousel_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_scandiweb_notification_carousel_form</namespace>
    </settings>
    <dataSource name="pagebuilder_scandiweb_notification_carousel_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_scandiweb_notification_carousel_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="appearance_fieldset" sortOrder="0" component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Type</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10" 
        component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceScandiwebNotificationCarousel"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="carousel_settings" sortOrder="10">
        <settings>
            <label translate="true">Carousel Settings</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="slider_count_desktop" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Slides Count on Desktop</label>
                <dataType>text</dataType>
                <dataScope>slider_count_desktop</dataScope>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="slider_count_tablet" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Slides Count on Tablet</label>
                <dataType>text</dataType>
                <dataScope>slider_count_tablet</dataScope>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="slider_count_mobile" sortOrder="30" formElement="input">
            <settings>
                <label translate="true">Slides Count on Mobile</label>
                <dataType>text</dataType>
                <dataScope>slider_count_mobile</dataScope>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="slider_show_arrows" sortOrder="40" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Show Arrows</label>
                <dataScope>slider_show_arrows</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="slider_infinitive" sortOrder="50" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Infinitive</label>
                <dataScope>slider_infinitive</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="general" sortOrder="30">
        <settings>
            <label/>
        </settings>
        <modal name="notification_carousel_item_modal">
            <settings>
                <options>
                    <option name="title" xsi:type="string" translate="true">Add Notification Carousel Item</option>
                </options>
            </settings>
            <insertForm name="notification_carousel_item_insert_form" component="Scandiweb_ContentTypes/js/form/components/notification-carousel-insert-form">
                <settings>
                    <toolbarContainer>${ $.parentName }</toolbarContainer>
                    <renderUrl path="mui/index/render_handle">
                        <param name="buttons">1</param>
                        <param name="handle">pagebuilder_scandiweb_notification_carousel_item_form</param>
                    </renderUrl>
                    <externalProvider>${ $.ns}.pagebuilder_scandiweb_notification_carousel_item_form_data_source</externalProvider>
                    <ns>pagebuilder_scandiweb_notification_carousel_item_form</ns>
                </settings>
            </insertForm>
        </modal>
        <container name="add_notification_carousel" sortOrder="10" template="ui/form/components/complex">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="content" xsi:type="string"/>
                    <item name="label" xsi:type="string"/>
                </item>
            </argument>
            <button name="add_notification_carousel_button">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="actions" xsi:type="array">
                            <item name="0" xsi:type="array">
                                <item name="targetName" xsi:type="string">index=notification_carousel_item_insert_form</item>
                                <item name="actionName" xsi:type="string">destroyInserted</item>
                            </item>
                            <item name="1" xsi:type="array">
                                <item name="targetName" xsi:type="string">index=notification_carousel_item_modal</item>
                                <item name="actionName" xsi:type="string">openModal</item>
                            </item>
                            <item name="2" xsi:type="array">
                                <item name="targetName" xsi:type="string">index=notification_carousel_item_insert_form</item>
                                <item name="actionName" xsi:type="string">render</item>
                            </item>
                        </item>
                    </item>
                </argument>
                <settings>
                    <title translate="true">Add Notification Carousel Item</title>
                </settings>
            </button>
        </container>
        <dynamicRows name="sections" sortOrder="20" component="Scandiweb_ContentTypes/js/form/components/notification-carousel-dynamic-rows" template="Magento_PageBuilder/form/components/dynamic-rows/edit-form-on-click-grid">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="insertFormProvider" xsi:type="string">index = notification_carousel_item_insert_form</item>
                    <item name="modalProvider" xsi:type="string">index=notification_carousel_item_modal</item>
                    <item name="emptyContentPlaceholder" xsi:type="string">No Notification Carousel Items found. Click "Add Notification Carousel Item"</item>
                </item>
            </argument>
            <settings>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">false</param>
                </dndConfig>
                <identificationProperty>record_id</identificationProperty>
                <addButton>false</addButton>
                <visible>true</visible>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="text" component="Magento_Ui/js/form/element/text" template="Scandiweb_ContentTypes/dynamic-rows/element/text-html" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Text</label>
                        <visible>true</visible>
                        <dataScope>text</dataScope>
                        <elementTmpl>ui/dynamic-rows/cells/text</elementTmpl>
                        <additionalClasses>
                            <class name="notification-carousel-text-preview">true</class>
                        </additionalClasses>
                    </settings>
                </field>
                <button name="actions" component="Magento_PageBuilder/js/form/components/action-button" template="Magento_PageBuilder/form/components/dynamic-rows/actions">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="insertFormProvider" xsi:type="string">index = notification_carousel_item_insert_form</item>
                            <item name="modalProvider" xsi:type="string">index = notification_carousel_item_modal</item>
                            <item name="noClickEdit" xsi:type="boolean">true</item>
                            <item name="actions" xsi:type="array">
                                <item name="0" xsi:type="array">
                                    <item name="targetName" xsi:type="string">${ $.name }</item>
                                    <item name="actionName" xsi:type="string">edit</item>
                                    <item name="label" xsi:type="string" translate="true">Edit</item>
                                </item>
                                <item name="1" xsi:type="array">
                                    <item name="targetName" xsi:type="string">${ $.name }</item>
                                    <item name="actionName" xsi:type="string">deleteRecord</item>
                                    <item name="label" xsi:type="string" translate="true">Delete</item>
                                </item>
                            </item>
                            <item name="label" translate="true" xsi:type="string">Select</item>
                        </item>
                    </argument>
                </button>
            </container>
        </dynamicRows>
        <field name="carousel_notice" formElement="input">
            <settings>
                <elementTmpl>ui/form/element/text</elementTmpl>
                <label translate="true"></label>
                <notice translate="true">
                    Note: Text in the table is shown in black for visibility; on the frontend, it will appear in your selected color (e.g., white, red, etc.). In the slide configuration, the text is displayed in the editor with all styling applied for an accurate preview.
                </notice>
            </settings>
        </field>
    </fieldset>
</form>